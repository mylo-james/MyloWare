{
  "title": "AISMR Video Generation Workflow",
  "memoryType": "procedural",
  "project": ["aismr"],
  "persona": [],
  "version": "1.0.0",
  "workflow": {
    "name": "Make Videos",
    "description": "Generate video using veo-3-fast API (8s, 9:16), edit with Shotstack (add timing overlays, audio at 3.0s)",
    "steps": [
      {
        "id": "load_video_config",
        "step": 1,
        "type": "mcp_call",
        "description": "Load veo-3-fast and Shotstack configuration from project prompts",
        "mcp_call": {
          "tool": "prompts.search",
          "params": {
            "query": "veo-3-fast API configuration settings 8 seconds 9:16 aspect ratio",
            "project": "aismr",
            "searchMode": "keyword",
            "limit": 10
          },
          "storeAs": "veoConfig"
        }
      },
      {
        "id": "load_shotstack_config",
        "step": 2,
        "type": "mcp_call",
        "description": "Load Shotstack edit parameters",
        "mcp_call": {
          "tool": "prompts.search",
          "params": {
            "query": "Shotstack edit parameters timing overlays audio whisper",
            "project": "aismr",
            "searchMode": "keyword",
            "limit": 10
          },
          "storeAs": "shotstackConfig"
        }
      },
      {
        "id": "generate_video",
        "step": 3,
        "type": "api_call",
        "description": "Call veo-3-fast API to generate video",
        "dependsOn": ["load_video_config"],
        "api_call": {
          "method": "POST",
          "url": "https://api.veo-3-fast.com/v1/generate",
          "headers": {
            "Authorization": "Bearer ${env.VEO_API_KEY}",
            "Content-Type": "application/json"
          },
          "body": {
            "prompt": "${context.screenplay.prompt}",
            "duration": 8,
            "aspect_ratio": "9:16",
            "resolution": "1080x1920"
          },
          "storeAs": "videoGenerationResult",
          "expectedStatusCodes": [200, 202]
        }
      },
      {
        "id": "poll_video_status",
        "step": 4,
        "type": "conditional",
        "description": "Poll video generation until complete",
        "dependsOn": ["generate_video"],
        "conditional": {
          "condition": "${videoGenerationResult.status} !== 'completed'",
          "ifTrue": "wait_and_poll",
          "ifFalse": "edit_video"
        },
        "retry": {
          "maxRetries": 30,
          "retryDelay": 5000,
          "backoffMultiplier": 1.2
        }
      },
      {
        "id": "wait_and_poll",
        "step": 5,
        "type": "api_call",
        "description": "Check video generation status",
        "dependsOn": ["poll_video_status"],
        "api_call": {
          "method": "GET",
          "url": "${videoGenerationResult.statusUrl}",
          "headers": {
            "Authorization": "Bearer ${env.VEO_API_KEY}"
          },
          "storeAs": "videoGenerationResult",
          "expectedStatusCodes": [200]
        }
      },
      {
        "id": "edit_video",
        "step": 6,
        "type": "api_call",
        "description": "Edit video with Shotstack: add timing overlays and audio at 3.0s",
        "dependsOn": ["poll_video_status", "load_shotstack_config"],
        "api_call": {
          "method": "POST",
          "url": "https://api.shotstack.io/v1/edit",
          "headers": {
            "Authorization": "Bearer ${env.SHOTSTACK_API_KEY}",
            "Content-Type": "application/json"
          },
          "body": {
            "timeline": {
              "soundtrack": {
                "src": "${context.screenplay.whisper_audio_url}",
                "effect": "fadeInOut",
                "trim": 0
              },
              "tracks": [
                {
                  "clips": [
                    {
                      "asset": {
                        "type": "video",
                        "src": "${videoGenerationResult.videoUrl}"
                      },
                      "start": 0,
                      "length": 8,
                      "effect": "zoomIn"
                    }
                  ]
                },
                {
                  "clips": [
                    {
                      "asset": {
                        "type": "title",
                        "text": "${context.screenplay.timestamps[0].action}",
                        "style": "minimal",
                        "position": "center"
                      },
                      "start": 0,
                      "length": 8
                    }
                  ]
                }
              ]
            },
            "output": {
              "format": "mp4",
              "resolution": "1080x1920",
              "fps": 30
            }
          },
          "storeAs": "editResult",
          "expectedStatusCodes": [200, 202]
        }
      },
      {
        "id": "poll_edit_status",
        "step": 7,
        "type": "conditional",
        "description": "Poll Shotstack edit until complete",
        "dependsOn": ["edit_video"],
        "conditional": {
          "condition": "${editResult.status} !== 'done'",
          "ifTrue": "wait_and_poll_edit",
          "ifFalse": "store_video"
        },
        "retry": {
          "maxRetries": 20,
          "retryDelay": 3000
        }
      },
      {
        "id": "wait_and_poll_edit",
        "step": 8,
        "type": "api_call",
        "description": "Check edit status",
        "dependsOn": ["poll_edit_status"],
        "api_call": {
          "method": "GET",
          "url": "${editResult.statusUrl}",
          "headers": {
            "Authorization": "Bearer ${env.SHOTSTACK_API_KEY}"
          },
          "storeAs": "editResult",
          "expectedStatusCodes": [200]
        }
      },
      {
        "id": "store_video",
        "step": 9,
        "type": "mcp_call",
        "description": "Store video metadata in episodic memory",
        "dependsOn": ["poll_edit_status"],
        "mcp_call": {
          "tool": "conversation.store",
          "params": {
            "sessionId": "${context.sessionId}",
            "role": "assistant",
            "content": "Generated AISMR video",
            "tags": ["aismr", "video-generation", "workflow-output"],
            "embeddingText": "AISMR video generated: ${editResult.videoUrl}",
            "metadata": {
              "stage": "video_generation",
              "workflowRunId": "${context.workflowRunId}",
              "videoUrl": "${editResult.videoUrl}",
              "duration": 8,
              "aspectRatio": "9:16"
            }
          }
        }
      }
    ],
    "output_format": {
      "type": "object",
      "properties": {
        "videoUrl": { "type": "string" },
        "duration": { "type": "number" },
        "aspectRatio": { "type": "string" },
        "resolution": { "type": "string" },
        "editMetadata": {
          "type": "object",
          "properties": {
            "overlays": { "type": "array" },
            "audioTiming": { "type": "number" }
          }
        }
      }
    }
  }
}

