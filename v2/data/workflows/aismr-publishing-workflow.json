{
  "title": "AISMR Video Publishing Workflow",
  "memoryType": "procedural",
  "project": ["aismr"],
  "persona": [],
  "version": "1.0.0",
  "workflow": {
    "name": "Post Video",
    "description": "Publish video to TikTok, YouTube Shorts, Instagram Reels in parallel with platform-specific captions and hashtags",
    "steps": [
      {
        "id": "load_publishing_config",
        "step": 1,
        "type": "parallel",
        "description": "Load platform-specific configurations in parallel",
        "parallel_calls": [
          {
            "tool": "memory_search",
            "params": {
              "query": "TikTok publishing settings caption hashtag templates",
              "project": "aismr",
              "searchMode": "keyword",
              "limit": 5
            },
            "storeAs": "tiktokConfig"
          },
          {
            "tool": "memory_search",
            "params": {
              "query": "YouTube Shorts publishing settings title description",
              "project": "aismr",
              "searchMode": "keyword",
              "limit": 5
            },
            "storeAs": "youtubeConfig"
          },
          {
            "tool": "memory_search",
            "params": {
              "query": "Instagram Reels publishing settings caption hashtags",
              "project": "aismr",
              "searchMode": "keyword",
              "limit": 5
            },
            "storeAs": "instagramConfig"
          }
        ]
      },
      {
        "id": "generate_captions",
        "step": 2,
        "type": "llm_generation",
        "description": "Generate platform-specific captions and hashtags",
        "dependsOn": ["load_publishing_config"],
        "llm_generation": {
          "model": "gpt-4",
          "prompt": "Generate platform-specific captions and metadata for this AISMR video: ${context.videoUrl}. TikTok config: ${tiktokConfig}, YouTube config: ${youtubeConfig}, Instagram config: ${instagramConfig}. Include engaging captions and relevant hashtags for each platform.",
          "schema": {
            "type": "object",
            "properties": {
              "tiktok": {
                "type": "object",
                "properties": {
                  "caption": { "type": "string" },
                  "hashtags": {
                    "type": "array",
                    "items": { "type": "string" }
                  }
                }
              },
              "youtube": {
                "type": "object",
                "properties": {
                  "title": { "type": "string", "maxLength": 100 },
                  "description": { "type": "string", "maxLength": 5000 },
                  "tags": {
                    "type": "array",
                    "items": { "type": "string" }
                  }
                }
              },
              "instagram": {
                "type": "object",
                "properties": {
                  "caption": { "type": "string" },
                  "hashtags": {
                    "type": "array",
                    "items": { "type": "string" }
                  }
                }
              }
            },
            "required": ["tiktok", "youtube", "instagram"]
          },
          "structuredOutput": true,
          "storeAs": "publishingMetadata",
          "temperature": 0.7
        }
      },
      {
        "id": "publish_tiktok",
        "step": 3,
        "type": "api_call",
        "description": "Publish to TikTok",
        "dependsOn": ["generate_captions"],
        "api_call": {
          "method": "POST",
          "url": "https://api.tiktok.com/v2/video/upload",
          "headers": {
            "Authorization": "Bearer ${env.TIKTOK_API_KEY}",
            "Content-Type": "application/json"
          },
          "body": {
            "video_url": "${context.videoUrl}",
            "caption": "${publishingMetadata.tiktok.caption}",
            "hashtags": "${publishingMetadata.tiktok.hashtags}",
            "privacy": "public"
          },
          "storeAs": "tiktokResult",
          "expectedStatusCodes": [200]
        }
      },
      {
        "id": "publish_youtube",
        "step": 4,
        "type": "api_call",
        "description": "Publish to YouTube Shorts",
        "dependsOn": ["generate_captions"],
        "api_call": {
          "method": "POST",
          "url": "https://www.googleapis.com/upload/youtube/v3/videos",
          "headers": {
            "Authorization": "Bearer ${env.YOUTUBE_API_KEY}",
            "Content-Type": "application/json"
          },
          "body": {
            "snippet": {
              "title": "${publishingMetadata.youtube.title}",
              "description": "${publishingMetadata.youtube.description}",
              "tags": "${publishingMetadata.youtube.tags}",
              "categoryId": "24"
            },
            "status": {
              "privacyStatus": "public"
            },
            "video_url": "${context.videoUrl}"
          },
          "storeAs": "youtubeResult",
          "expectedStatusCodes": [200]
        }
      },
      {
        "id": "publish_instagram",
        "step": 5,
        "type": "api_call",
        "description": "Publish to Instagram Reels",
        "dependsOn": ["generate_captions"],
        "api_call": {
          "method": "POST",
          "url": "https://graph.instagram.com/v1/media",
          "headers": {
            "Authorization": "Bearer ${env.INSTAGRAM_API_KEY}",
            "Content-Type": "application/json"
          },
          "body": {
            "video_url": "${context.videoUrl}",
            "caption": "${publishingMetadata.instagram.caption}",
            "hashtags": "${publishingMetadata.instagram.hashtags}"
          },
          "storeAs": "instagramResult",
          "expectedStatusCodes": [200]
        }
      },
      {
        "id": "store_publishing_results",
        "step": 6,
        "type": "mcp_call",
        "description": "Store publishing results and URLs in episodic memory",
        "dependsOn": ["publish_tiktok", "publish_youtube", "publish_instagram"],
        "mcp_call": {
          "tool": "memory_store",
          "params": {
            "sessionId": "${context.sessionId}",
            "role": "assistant",
            "content": "Published video to all platforms",
            "tags": ["aismr", "publishing", "workflow-output"],
            "embeddingText": "Published AISMR video: TikTok ${tiktokResult.url}, YouTube ${youtubeResult.url}, Instagram ${instagramResult.url}",
            "metadata": {
              "stage": "publishing",
              "workflowRunId": "${context.workflowRunId}",
              "platforms": {
                "tiktok": {
                  "url": "${tiktokResult.url}",
                  "postId": "${tiktokResult.postId}"
                },
                "youtube": {
                  "url": "${youtubeResult.url}",
                  "videoId": "${youtubeResult.videoId}"
                },
                "instagram": {
                  "url": "${instagramResult.url}",
                  "mediaId": "${instagramResult.mediaId}"
                }
              }
            }
          }
        }
      }
    ],
    "output_format": {
      "type": "object",
      "properties": {
        "platforms": {
          "type": "object",
          "properties": {
            "tiktok": {
              "type": "object",
              "properties": {
                "url": { "type": "string" },
                "postId": { "type": "string" },
                "status": { "type": "string" }
              }
            },
            "youtube": {
              "type": "object",
              "properties": {
                "url": { "type": "string" },
                "videoId": { "type": "string" },
                "status": { "type": "string" }
              }
            },
            "instagram": {
              "type": "object",
              "properties": {
                "url": { "type": "string" },
                "mediaId": { "type": "string" },
                "status": { "type": "string" }
              }
            }
          }
        },
        "publishingMetadata": {
          "type": "object",
          "properties": {
            "tiktok": { "type": "object" },
            "youtube": { "type": "object" },
            "instagram": { "type": "object" }
          }
        }
      }
    }
  }
}

