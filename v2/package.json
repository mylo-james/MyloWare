{
  "name": "mcp-prompts-v2",
  "version": "2.0.0",
  "description": "V2: Agentic RAG system with semantic workflow discovery",
  "main": "dist/server.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc --project tsconfig.json",
    "start": "node dist/server.js",
    "type-check": "tsc --noEmit",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:unit": "vitest run --dir tests/unit",
    "test:integration": "vitest run --dir tests/integration",
    "test:e2e": "vitest run --dir tests/e2e",
    "test:perf": "vitest run --dir tests/performance",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "db:reset": "tsx scripts/db/reset.ts",
    "db:migrate": "drizzle-kit up",
    "db:seed": "tsx scripts/db/seed.ts",
    "db:seed:test": "tsx scripts/db/seed-test.ts",
    "db:status": "drizzle-kit check:pg",
    "migrate:personas": "tsx scripts/migrate/personas.ts",
    "migrate:projects": "tsx scripts/migrate/projects.ts",
    "migrate:workflows": "tsx scripts/migrate/workflows.ts",
    "migrate:all": "npm run migrate:personas && npm run migrate:projects && npm run migrate:workflows",
    "test:mcp": "tsx scripts/test-mcp-client.ts"
  },
  "dependencies": {
    "@fastify/cors": "^11.1.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/rate-limit": "^10.3.0",
    "@modelcontextprotocol/sdk": "^1.20.2",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.44.7",
    "fastify": "^5.6.1",
    "openai": "^6.7.0",
    "pg": "^8.16.3",
    "pgvector": "^0.2.1",
    "pino": "^10.1.0",
    "prom-client": "^15.1.3",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^24.9.2",
    "@types/pg": "^8.15.6",
    "@typescript-eslint/eslint-plugin": "^8.46.2",
    "@typescript-eslint/parser": "^8.46.2",
    "@vitest/coverage-v8": "^4.0.4",
    "drizzle-kit": "^0.31.6",
    "eslint": "^9.38.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.6.2",
    "testcontainers": "^11.8.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^4.0.4"
  }
}
