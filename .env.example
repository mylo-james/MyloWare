# Application
NODE_ENV=development
SERVER_HOST=0.0.0.0
SERVER_PORT=3456

# Database
MCP_DB_USER=mcp_prompts
MCP_DB_PASSWORD=change-me
MCP_DB_NAME=mcp_prompts
DATABASE_URL=postgresql://${MCP_DB_USER}:${MCP_DB_PASSWORD}@localhost:5442/${MCP_DB_NAME}
# Optional: SQL database for runs/videos (leave empty to disable operations tools)
OPERATIONS_DATABASE_URL=

# Optional: default sub-workflow for the Mylo MCP agent (n8n workflow ID)
MYLO_MCP_WORKFLOW_ID=

# OpenAI Embeddings
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# n8n Integration
N8N_BASE_URL=https://your-n8n-instance.example
N8N_API_KEY=

# Full-text search
FULLTEXT_SEARCH_WEIGHTS=1.0,0.4,0.2,0.1
FULLTEXT_MIN_SCORE=0.1
FULLTEXT_SEARCH_LANGUAGE=english

# Hybrid search
HYBRID_RRF_K=60
HYBRID_VECTOR_WEIGHT=0.6
HYBRID_KEYWORD_WEIGHT=0.4

# Memory routing
MEMORY_ROUTING_ENABLED=false
MEMORY_ROUTING_ROLLOUT_PCT=0

# Auto mode selection
AUTO_MODE_ENABLED=true
TECHNICAL_PATTERN_REGEX=(?:[A-Z]{2,}\d{2,}|[_:\-]{3,}|\b[A-Za-z]+[_-]id\b)
AUTO_MODE_KEYWORD_WEIGHT=1
AUTO_MODE_VECTOR_WEIGHT=1
AUTO_MODE_HYBRID_WEIGHT=1

# Temporal decay
TEMPORAL_DECAY_ENABLED=false
TEMPORAL_DECAY_FUNCTION=exponential
TEMPORAL_DECAY_HALFLIFE_DAYS=90
TEMPORAL_DECAY_MAX_AGE_DAYS=365

# Episodic memory
EPISODIC_MEMORY_ENABLED=true
EPISODIC_SUMMARY_THRESHOLD_DAYS=30
EPISODIC_SUMMARY_BATCH_LIMIT=100

# Memory graph
MEMORY_GRAPH_MAX_NEIGHBORS=20
MEMORY_GRAPH_SIMILAR_THRESHOLD=0.75
MEMORY_GRAPH_RELATED_THRESHOLD=0.5
MEMORY_GRAPH_MIN_STRENGTH=0.45
MEMORY_GRAPH_BIDIRECTIONAL=true
