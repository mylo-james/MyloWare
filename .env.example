# =============================================================================
# MyloWare Environment Configuration
# =============================================================================

# -----------------------------------------------------------------------------
# Llama Stack
# -----------------------------------------------------------------------------
LLAMA_STACK_URL=http://localhost:5001
TOGETHER_API_KEY=your_together_api_key
OPENAI_API_KEY=your_openai_api_key

# Model selection (OpenAI models via Llama Stack):
# - openai/gpt-4o-mini    (default, fast, cost-effective)
# - openai/gpt-4o         (better quality, still fast)
# - openai/gpt-5-nano     (next-gen, very fast)
# - openai/gpt-5          (next-gen, best quality)
LLAMA_STACK_MODEL=openai/gpt-4o-mini

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/myloware
POSTGRES_DB=myloware
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# -----------------------------------------------------------------------------
# API Security
# -----------------------------------------------------------------------------
API_KEY=your_secure_api_key

# -----------------------------------------------------------------------------
# Environment
# -----------------------------------------------------------------------------
ENVIRONMENT=development
PUBLIC_BASE_URL=http://localhost:8000

# -----------------------------------------------------------------------------
# Webhooks
# -----------------------------------------------------------------------------
# Your public URL where KIE.ai and Remotion send callbacks.
# Production: Your Fly.io URL (automatically public)
# Local dev: Use ngrok (ngrok http 8000) or cloudflared, or just use fake providers
#
# Example for Fly.io:
WEBHOOK_BASE_URL=https://myloware.fly.dev
#
# Example for ngrok (local testing with real APIs):
# WEBHOOK_BASE_URL=https://abc123.ngrok.io

# -----------------------------------------------------------------------------
# Telegram
# -----------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
TELEGRAM_USER_ID=your_telegram_user_id

# -----------------------------------------------------------------------------
# KIE.ai (Video Generation)
# -----------------------------------------------------------------------------
KIE_API_KEY=your_kie_api_key
KIE_API_URL=https://api.kie.ai
KIE_SIGNING_SECRET=your_kie_signing_secret

# -----------------------------------------------------------------------------
# Remotion (Self-hosted Rendering)
# -----------------------------------------------------------------------------
REMOTION_SERVICE_URL=http://remotion-service:3001
REMOTION_WEBHOOK_SECRET=change_this_to_a_strong_random_value

# -----------------------------------------------------------------------------
# Upload-Post (TikTok Publishing)
# -----------------------------------------------------------------------------
UPLOAD_POST_API_KEY=your_upload_post_api_key
UPLOAD_POST_API_URL=https://api.upload-post.dev
UPLOAD_POST_SIGNING_SECRET=your_upload_post_signing_secret

# -----------------------------------------------------------------------------
# Langfuse (LLM Observability)
# -----------------------------------------------------------------------------
# For local development with docker-compose:
#   1. Start: docker compose up -d
#   2. Open http://localhost:3000 and create account
#   3. Create a project, copy the API keys below
#
# For Langfuse Cloud (https://cloud.langfuse.com):
#   1. Sign up and create a project
#   2. Copy your API keys below
#   3. Set LANGFUSE_HOST=https://cloud.langfuse.com (or remove it)
LANGFUSE_PUBLIC_KEY=pk-lf-your-public-key
LANGFUSE_SECRET_KEY=sk-lf-your-secret-key
LANGFUSE_HOST=http://localhost:3000
