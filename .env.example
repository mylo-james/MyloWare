# Supabase Configuration
# Copy this file to .env and fill in your actual values

# For n8n workflows and Supabase SDK
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here

# For direct PostgreSQL access (dev scripts)
# Get from: Supabase Dashboard → Settings → Database → Connection String (URI)
# Format: postgresql://postgres:[YOUR-PASSWORD]@db.your-project.supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:your-password@db.your-project.supabase.co:5432/postgres

# n8n API Sync (npm run n8n:push / n8n:pull)
# Required
N8N_BASE_URL=https://n8n.example.com
N8N_API_KEY=your-n8n-api-key

# Optional overrides (leave commented unless you need custom locations)
# N8N_API_PREFIX=/api/v1
# N8N_WORKFLOW_DIR=workflows
# N8N_WORKFLOW_MANIFEST=workflows/workflow-map.json
