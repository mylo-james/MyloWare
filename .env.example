# Core services
DATABASE_URL=postgresql://mylo:password@localhost:5432/mcp_prompts
OPENAI_API_KEY=
MCP_AUTH_KEY=mylo-mcp-bot

# Bot + workflow integrations
TELEGRAM_BOT_TOKEN=telegram-placeholder-token
TELEGRAM_USER_ID=123456789
N8N_WEBHOOK_URL=https://example.com/webhook
N8N_PORT=5678
N8N_USER=admin
N8N_PASSWORD=admin

# Local development options
SERVER_PORT=3000
SERVER_HOST=0.0.0.0
LOG_LEVEL=info
DB_PASSWORD=postgres
POSTGRES_PORT=5432

# Security Configuration
# Comma-separated list of allowed CORS origins. Empty (default) rejects all cross-origin requests.
ALLOWED_CORS_ORIGINS=http://localhost:5678,http://n8n:5678,https://n8n.yourdomain.com

# Comma-separated list of hostnames/IPs allowed to connect (DNS rebinding protection)
ALLOWED_HOST_KEYS=127.0.0.1,localhost,mcp-server,mcp-vector.yourdomain.com

# Enable detailed auth logging (NEVER enable in production)
DEBUG_AUTH=false

# Session Configuration
# Time-to-live for session transports in milliseconds (default 3600000 = 1 hour)
SESSION_TTL_MS=3600000
# Maximum number of active sessions to keep in memory (per process)
MAX_SESSIONS_PER_USER=10

# Web Fetch Configuration
# User agent string for web requests
WEB_FETCH_USER_AGENT=MyloWareBot/1.0
# Timeout for web requests in milliseconds (default 10000 = 10 seconds)
WEB_FETCH_TIMEOUT_MS=10000
# Web search uses built-in DuckDuckGo scraper (no API key needed)
