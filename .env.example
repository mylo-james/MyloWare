# Core (minimal essentials)
ENVIRONMENT=development
API_KEY=dev-api-key
LLAMA_STACK_URL=http://localhost:5001
LLAMA_STACK_MODEL=openai/gpt-5-nano
LLAMA_STACK_PROVIDER=fake
OPENAI_STANDARD_WEBHOOK_SECRET=
OPENAI_SORA_SIGNING_SECRET=
SORA_PROVIDER=fake
REMOTION_PROVIDER=fake
UPLOAD_POST_PROVIDER=fake
DISABLE_BACKGROUND_WORKFLOWS=true

# Providers (only if you use real services)
WEBHOOK_BASE_URL=http://localhost:8000
REMOTION_SERVICE_URL=http://localhost:3001
REMOTION_API_SECRET=
# Remotion sandbox configuration (SECURITY: defaults to enabled for safety)
# WARNING: Disabling sandbox or allowing composition code in production requires careful review.
# Sandbox provides isolation and prevents arbitrary code execution.
REMOTION_SANDBOX_ENABLED=true
REMOTION_ALLOW_COMPOSITION_CODE=true
# Note: Both flags must be true for custom TSX code (sandbox is mandatory for security)
# In production, review these settings carefully and ensure sandbox isolation is adequate.

# External keys (optional)
BRAVE_API_KEY=
SENTRY_DSN=

# Observability (debug only; payloads may contain sensitive data)
LOG_WEBHOOK_PAYLOADS=false

# Transcode / SSRF guard
TRANSCODE_MAX_CONCURRENCY=2
TRANSCODE_ALLOW_PRIVATE=false
TRANSCODE_ALLOWED_DOMAINS=[]

# Cost guards
MAX_RUNS_LAST_24H=1000
DAILY_COST_BUDGET_USD=200
ESTIMATED_COST_PER_RUN_USD=0.5

# Per-provider Sora debugging
# SORA_PROVIDER=real|fake|off
# SORA_FAKE_CLIPS_DIR=fake_clips/sora
# SORA_FAKE_CLIP_PATHS=/abs/path/to/clip1.mp4,/abs/path/to/clip2.mp4
