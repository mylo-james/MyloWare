{
  "name": "genreact",
  "title": "GenReact - Generational Reactions",
  "description": "How each generation reacts to modern situations. Humorous but respectful, culturally accurate, age-appropriate.",
  
  "workflow": ["casey", "iggy", "riley", "veo", "alex", "quinn"],
  "optionalSteps": ["alex"],
  
  "specs": {
    "videoCount": 6,
    "videoDuration": 8.0,
    "generations": [
      "Silent",
      "Boomer",
      "GenX",
      "Millennial",
      "GenZ",
      "Alpha"
    ],
    "compilationLength": 54,
    "format": "9:16 vertical, generation labels",
    "aspectRatio": "9:16",
    "resolution": "1080x1920"
  },
  
  "guardrails": {
    "tone": {
      "humor": {
        "rule": "Humorous but respectful",
        "guidelines": ["Light observational comedy", "No mockery", "Celebrate differences"]
      },
      "respect": {
        "rule": "Never mock or belittle any generation",
        "validation": "Iggy and Riley must ensure respectful tone",
        "enforcement": "Strict - any mockery fails validation"
      }
    },
    "accuracy": {
      "cultural": {
        "rule": "Culturally accurate for each generation",
        "validation": "Iggy must research generational characteristics",
        "guidelines": ["Authentic reactions", "Age-appropriate", "Historically accurate"]
      },
      "age_appropriate": {
        "rule": "Content appropriate for generation's age range",
        "validation": "Riley must ensure age-appropriateness",
        "guidelines": ["No adult themes for younger generations", "Respectful of life experience"]
      }
    },
    "style": {
      "observational": {
        "rule": "Light observational comedy",
        "guidelines": ["Recognizable patterns", "Relatable moments", "Gentle humor"]
      },
      "representation": {
        "rule": "Each generation represented fairly",
        "validation": "Iggy ensures all 6 generations covered",
        "guidelines": ["Equal screen time", "Balanced perspectives"]
      }
    },
    "format": {
      "labels": {
        "rule": "Generation labels visible",
        "validation": "Alex ensures labels in compilation",
        "format": "Clear, readable generation name"
      },
      "sequence": {
        "rule": "Sequential by generation order",
        "validation": "Alex ensures correct order",
        "order": "Silent → Boomer → GenX → Millennial → GenZ → Alpha"
      }
    }
  },
  
  "agent_expectations": {
    "casey": {
      "output": "Trace created, kickoff logged, handoff to iggy",
      "instructions_template": "Develop {specs.videoCount} generational scenarios for {topic} (GenReact project). Cover {specs.generations.join(', ')}. Validate cultural accuracy. Seek approval, hand to Riley.",
      "success_criteria": [
        "Project identified correctly",
        "Trace created with traceId",
        "Clear instructions for Iggy"
      ]
    },
    "iggy": {
      "output": "{specs.videoCount} generational scenarios",
      "validation": [
        "Cultural accuracy for each generation",
        "All {specs.generations.length} generations represented",
        "Respectful tone (no mockery)"
      ],
      "format": "Scenario name + generation + brief description",
      "examples": [
        "Silent Generation: 'What's a smartphone?' - Confused by technology",
        "Boomer: 'Back in my day...' - Compares to past"
      ],
      "success_criteria": [
        "{specs.videoCount} scenarios generated",
        "All generations represented",
        "Cultural accuracy validated",
        "Respectful tone ensured"
      ]
    },
    "riley": {
      "output": "{specs.videoCount} validated screenplays",
      "validation": [
        "Timing: 8.0s per screenplay",
        "Age-appropriate content",
        "Respectful tone",
        "Generation characteristics accurate"
      ],
      "format": "Timestamp-based shot list with generation-specific dialogue",
      "success_criteria": [
        "{specs.videoCount} screenplays written",
        "All timing specs validated",
        "All guardrails followed",
        "Generation authenticity ensured"
      ]
    },
    "veo": {
      "output": "{specs.videoCount} video URLs",
      "validation": "All jobs succeeded (jobs_summary confirms)",
      "tracking": "Use job_upsert for each video",
      "success_criteria": [
        "{specs.videoCount} videos generated",
        "All jobs tracked",
        "All URLs accessible",
        "jobs_summary confirms completion"
      ]
    },
    "alex": {
      "output": "1 final compilation URL (~{specs.compilationLength}s) OR skip if simple",
      "validation": [
        "User approval via HITL (if editing)",
        "Duration: ~{specs.compilationLength}s",
        "Format: Sequential with generation labels",
        "All {specs.videoCount} videos included"
      ],
      "format": "Sequential compilation with generation labels",
      "optional": true,
      "skip_logic": "If videos are already sequential and good quality, Veo can hand directly to Quinn",
      "success_criteria": [
        "Compilation created (if editing)",
        "User approved (if editing)",
        "Generation labels included",
        "Format matches project requirements"
      ]
    },
    "quinn": {
      "output": "Published URL + platform confirmation",
      "validation": "Upload succeeded",
      "platforms": ["tiktok"],
      "caption": "Platform-appropriate with generational hashtags",
      "success_criteria": [
        "Video published successfully",
        "Publish URL received",
        "Caption optimized",
        "Completion signaled"
      ]
    }
  },
  
  "quality_metrics": {
    "cultural_accuracy": {
      "target": "100%",
      "measurement": "Iggy's validation",
      "threshold": "Each generation authentically represented"
    },
    "respect_score": {
      "target": "≥95%",
      "measurement": "Iggy and Riley validation",
      "threshold": "No mockery, respectful tone"
    },
    "generation_coverage": {
      "target": "100%",
      "measurement": "Iggy ensures all 6 generations",
      "threshold": "All {specs.generations.length} generations represented"
    },
    "user_approval_rate": {
      "target": "≥90%",
      "measurement": "Iggy HITL approvals",
      "handling": "Incorporate feedback on rejection"
    }
  },
  
  "example_outputs": {
    "iggy": {
      "scenarios": [
        "Silent Generation: Reacts to AI with confusion and wonder",
        "Boomer: Compares AI to 'back in my day' technology",
        "GenX: Skeptical but curious about AI capabilities"
      ],
      "count": 6
    },
    "riley": {
      "screenplay_example": {
        "title": "Boomer Reacts to AI",
        "generation": "Boomer",
        "timestamps": {
          "0.0s": "Hook: Boomer sees AI demo",
          "3.0s": "Dialogue: 'Back in my day, we had typewriters...'",
          "8.0s": "Resolution: Boomer impressed but nostalgic"
        },
        "tone": "Respectful, humorous, nostalgic"
      }
    }
  }
}
