{
  "name": "aismr",
  "title": "AISMR - Surreal Object Videos",
  "description": "8-second micro-films of everyday objects with impossible modifiers. Tactile, mesmerizing, slightly unsettling.",
  
  "workflow": ["casey", "iggy", "riley", "veo", "alex", "quinn"],
  "optionalSteps": [],
  
  "specs": {
    "videoCount": 12,
    "videoDuration": 8.0,
    "whisperTiming": 3.0,
    "maxHands": 2,
    "compilationLength": 110,
    "format": "9:16 vertical, single-shot, no cuts",
    "aspectRatio": "9:16",
    "resolution": "1080x1920"
  },
  
  "guardrails": {
    "timing": {
      "runtime": {
        "rule": "Exactly 8.0s ±0.1s per video",
        "validation": "Riley must validate before storing",
        "tolerance": "±0.1s"
      },
      "whisper": {
        "rule": "Single whispered word at 3.0s ±0.05s",
        "validation": "Riley must validate timing",
        "tolerance": "±0.05s"
      },
      "compilation": {
        "rule": "Total compilation ~110s (12 videos + title cards)",
        "validation": "Alex validates before storing"
      }
    },
    "visual": {
      "hands": {
        "rule": "Maximum 2 hands visible at any time",
        "validation": "Riley must state hand count explicitly",
        "enforcement": "Strict - no exceptions"
      },
      "camera": {
        "rule": "Single continuous shot, no cuts or transitions",
        "validation": "Riley must ensure continuity",
        "style": "Macro focus, object-centric"
      },
      "focus": {
        "rule": "Tactile, macro, object-centric",
        "guidelines": ["Close-up on object", "Textures emphasized", "Minimal background"]
      }
    },
    "audio": {
      "music": {
        "rule": "Forbidden - no music allowed",
        "validation": "Riley must explicitly state 'no music'",
        "enforcement": "Strict - any music fails validation"
      },
      "voice": {
        "rule": "Single whispered word at 3.0s",
        "guidelines": ["ASMR-style whisper", "One word only", "Tactile sound"]
      },
      "foley": {
        "rule": "Required - tactile, realistic foley sounds",
        "guidelines": ["Object interactions", "Material sounds", "Ambient texture"]
      }
    },
    "style": {
      "modifiers": {
        "rule": "Surreal, impossible physics",
        "examples": ["Void (absorbs light)", "Liquid (flows upward)", "Crystal (transparent glow)"],
        "guidelines": ["Impossible but believable", "Tactile focus", "Mesmerizing"]
      },
      "mood": {
        "rule": "Mesmerizing, slightly unsettling",
        "guidelines": ["Hypnotic motion", "Subtle unease", "Beautiful but strange"]
      },
      "originality": {
        "rule": "Must validate uniqueness against archive",
        "validation": "Iggy checks before storing",
        "threshold": "Similarity <0.85"
      }
    }
  },
  
  "agent_expectations": {
    "casey": {
      "output": "Trace created, kickoff logged, handoff to iggy",
      "instructions_template": "Generate {specs.videoCount} surreal modifiers for {object} (AISMR project). Validate uniqueness against archive. Seek approval via HITL. When approved, hand to Riley with modifier list.",
      "success_criteria": [
        "Project identified correctly",
        "Trace created with traceId",
        "Clear instructions for Iggy"
      ]
    },
    "iggy": {
      "output": "{specs.videoCount} surreal object modifiers",
      "validation": "Uniqueness checked against archive (similarity <0.85)",
      "format": "Modifier name + brief description",
      "examples": ["Void Candle - Flame absorbs light", "Liquid Candle - Wax flows upward"],
      "success_criteria": [
        "{specs.videoCount} modifiers generated",
        "Uniqueness validated",
        "All follow style guardrails (surreal, tactile)"
      ]
    },
    "riley": {
      "output": "{specs.videoCount} validated screenplays",
      "validation": [
        "Timing: 8.0s ±0.1s per screenplay",
        "Whisper: 3.0s ±0.05s",
        "Hands: ≤2 explicitly stated",
        "Audio: No music, foley described",
        "Format: Single-shot, no cuts"
      ],
      "format": "Timestamp-based shot list with explicit timing",
      "success_criteria": [
        "{specs.videoCount} screenplays written",
        "All timing specs validated",
        "All guardrails followed",
        "Production-ready (clear, actionable)"
      ]
    },
    "veo": {
      "output": "{specs.videoCount} video URLs",
      "validation": "All jobs succeeded (jobs_summary confirms)",
      "tracking": "Use job_upsert for each video",
      "success_criteria": [
        "{specs.videoCount} videos generated",
        "All jobs tracked",
        "All URLs accessible",
        "jobs_summary confirms completion"
      ]
    },
    "alex": {
      "output": "1 final compilation URL (~{specs.compilationLength}s)",
      "validation": [
        "User approval via HITL",
        "Duration: ~{specs.compilationLength}s",
        "Format: Sequential with title cards",
        "All {specs.videoCount} videos included"
      ],
      "format": "Sequential compilation with title cards between videos",
      "success_criteria": [
        "Compilation created",
        "User approved",
        "Duration matches spec",
        "Format matches project requirements"
      ]
    },
    "quinn": {
      "output": "Published URL + platform confirmation",
      "validation": "Upload succeeded",
      "platforms": ["tiktok"],
      "caption": "Platform-appropriate with #AISMR hashtag",
      "success_criteria": [
        "Video published successfully",
        "Publish URL received",
        "Caption optimized",
        "Completion signaled"
      ]
    }
  },
  
  "quality_metrics": {
    "uniqueness_collisions": {
      "target": 0,
      "measurement": "Iggy's uniqueness validation",
      "threshold": "Similarity <0.85"
    },
    "timing_deviations": {
      "target": 0,
      "measurement": "Riley's validation",
      "tolerance": "±0.1s runtime, ±0.05s whisper"
    },
    "video_failure_rate": {
      "target": "≤5%",
      "measurement": "Veo's job tracking",
      "handling": "Document reasons for failures"
    },
    "user_approval_rate": {
      "target": "≥90%",
      "measurement": "Iggy and Alex HITL approvals",
      "handling": "Incorporate feedback on rejection"
    }
  },
  
  "example_outputs": {
    "iggy": {
      "modifiers": [
        "Void Candle - Flame absorbs light, creates darkness",
        "Liquid Candle - Wax flows upward against gravity",
        "Crystal Candle - Transparent with inner bioluminescent glow"
      ],
      "count": 12
    },
    "riley": {
      "screenplay_example": {
        "title": "Void Candle",
        "timestamps": {
          "0.0s": "Hook: Candle appears normal",
          "3.0s": "Whisper: 'void'",
          "8.0s": "Resolution: Flame absorbs all light"
        },
        "hands": 1,
        "audio": "No music, tactile foley only"
      }
    }
  }
}
