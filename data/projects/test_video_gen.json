{
  "name": "test_video_gen",
  "title": "Test Video Generation",
  "description": "Simple test project that generates two videos: moon with 'cheeseburger' header and sun with 'pickle' header. Used for testing the full workflow pipeline.",
  
  "workflow": ["casey", "iggy", "riley", "veo", "alex", "quinn"],
  "optionalSteps": [],
  
  "specs": {
    "videoCount": 2,
    "videoDuration": 10.0,
    "videos": [
      {
        "subject": "moon",
        "header": "cheeseburger"
      },
      {
        "subject": "sun",
        "header": "pickle"
      }
    ],
    "compilationLength": 25,
    "format": "9:16 vertical, header text overlay",
    "aspectRatio": "9:16",
    "resolution": "1080x1920"
  },
  
  "guardrails": {
    "content": {
      "subjects": {
        "rule": "Must create exactly 2 videos: moon and sun",
        "validation": "Iggy must ensure both subjects are included",
        "enforcement": "Strict - both videos required"
      },
      "headers": {
        "rule": "Moon video must have 'cheeseburger' header, sun video must have 'pickle' header",
        "validation": "Riley must ensure headers are correct in screenplays",
        "enforcement": "Strict - headers must match exactly"
      }
    },
    "visual": {
      "header_style": {
        "rule": "Header text must be clearly visible and readable",
        "guidelines": ["Large, bold text", "High contrast", "Centered or top-aligned"],
        "validation": "Riley must specify header placement in screenplay"
      },
      "subject_focus": {
        "rule": "Subject (moon/sun) must be clearly visible",
        "guidelines": ["Subject is main focus", "Header doesn't obscure subject", "Good composition"]
      }
    },
    "format": {
      "duration": {
        "rule": "Each video ~10 seconds",
        "validation": "Riley validates timing",
        "tolerance": "±1.0s"
      },
      "compilation": {
        "rule": "Total compilation ~25s (2 videos + transitions)",
        "validation": "Alex validates before storing"
      }
    },
    "style": {
      "test_purpose": {
        "rule": "This is a test project - keep it simple and functional",
        "guidelines": ["Focus on workflow validation", "Simple visuals", "Clear headers"]
      }
    }
  },
  
  "agent_expectations": {
    "casey": {
      "output": "Trace created, kickoff logged, handoff to iggy",
      "instructions_template": "Generate ideas for 2 test videos: moon with 'cheeseburger' header and sun with 'pickle' header (test_video_gen project). Keep it simple for testing. When approved, hand to Riley.",
      "success_criteria": [
        "Project identified correctly",
        "Trace created with traceId",
        "Clear instructions for Iggy"
      ]
    },
    "iggy": {
      "output": "2 video ideas (moon + sun)",
      "validation": [
        "Both subjects included (moon and sun)",
        "Headers specified correctly (cheeseburger for moon, pickle for sun)"
      ],
      "format": "Subject name + header text + brief description",
      "examples": [
        "Moon - Header: 'cheeseburger' - Celestial body with cheeseburger text overlay",
        "Sun - Header: 'pickle' - Bright sun with pickle text overlay"
      ],
      "success_criteria": [
        "2 ideas generated",
        "Moon idea includes 'cheeseburger' header",
        "Sun idea includes 'pickle' header",
        "Both subjects clearly described"
      ]
    },
    "riley": {
      "output": "2 validated screenplays",
      "validation": [
        "Timing: ~10.0s per screenplay (±1.0s tolerance)",
        "Headers: Moon has 'cheeseburger', Sun has 'pickle'",
        "Header placement clearly specified",
        "Subject visibility ensured"
      ],
      "format": "Timestamp-based shot list with header text specification",
      "success_criteria": [
        "2 screenplays written",
        "All timing specs validated",
        "Headers correctly assigned",
        "Header placement specified",
        "Production-ready (clear, actionable)"
      ]
    },
    "veo": {
      "output": "2 video URLs",
      "validation": "All jobs succeeded (jobs_summary confirms)",
      "tracking": "Use job_upsert for each video",
      "success_criteria": [
        "2 videos generated",
        "All jobs tracked",
        "All URLs accessible",
        "jobs_summary confirms completion"
      ]
    },
    "alex": {
      "output": "1 final compilation URL (~25s)",
      "validation": [
        "Duration: ~25s",
        "Format: Sequential with both videos",
        "Both videos included",
        "Transitions smooth"
      ],
      "format": "Sequential compilation with both videos",
      "success_criteria": [
        "Compilation created",
        "Duration matches spec (~25s)",
        "Both videos included",
        "Format matches project requirements"
      ]
    },
    "quinn": {
      "output": "Published URL + platform confirmation",
      "validation": "Upload succeeded",
      "platforms": ["tiktok"],
      "test_account": true,
      "caption": "Platform-appropriate test caption",
      "success_criteria": [
        "Video published successfully to test account",
        "Publish URL received",
        "Caption optimized",
        "Completion signaled"
      ]
    }
  },
  
  "quality_metrics": {
    "header_accuracy": {
      "target": "100%",
      "measurement": "Riley's validation",
      "threshold": "Headers match exactly (moon=cheeseburger, sun=pickle)"
    },
    "subject_coverage": {
      "target": "100%",
      "measurement": "Iggy ensures both subjects",
      "threshold": "Both moon and sun included"
    },
    "video_failure_rate": {
      "target": "≤5%",
      "measurement": "Veo's job tracking",
      "handling": "Document reasons for failures"
    },
    "workflow_completion": {
      "target": "100%",
      "measurement": "End-to-end workflow success",
      "threshold": "Full pipeline completes successfully"
    }
  },
  
  "example_outputs": {
    "iggy": {
      "ideas": [
        "Moon - Header: 'cheeseburger' - Night sky with full moon, large 'cheeseburger' text overlay",
        "Sun - Header: 'pickle' - Bright sun in sky, large 'pickle' text overlay"
      ],
      "count": 2
    },
    "riley": {
      "screenplay_example": {
        "title": "Moon with Cheeseburger Header",
        "subject": "moon",
        "header": "cheeseburger",
        "timestamps": {
          "0.0s": "Fade in: Moon appears in night sky",
          "2.0s": "Header text 'cheeseburger' fades in at top center",
          "5.0s": "Moon and header both clearly visible",
          "10.0s": "Fade out"
        },
        "header_placement": "Top center, large bold text, high contrast"
      }
    }
  }
}

