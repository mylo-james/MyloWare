{
  "title": "AISMR Screenplay Generation Workflow",
  "memoryType": "procedural",
  "project": ["aismr"],
  "persona": ["screenwriter"],
  "version": "1.0.0",
  "workflow": {
    "name": "Write Script",
    "description": "Generate AISMR screenplay with precise timing (8.0s runtime, 3.0s whisper, max 2 hands), validate against specs",
    "steps": [
      {
        "id": "load_specs",
        "step": 1,
        "type": "parallel",
        "description": "Load all AISMR specs in parallel using keyword search",
        "parallel_calls": [
          {
            "tool": "memory_search",
            "params": {
              "query": "AISMR runtime 8 seconds specification",
              "project": "aismr",
              "limit": 5
            },
            "storeAs": "runtimeSpec"
          },
          {
            "tool": "memory_search",
            "params": {
              "query": "AISMR whisper timing 3.0 seconds specification",
              "project": "aismr",
              "limit": 5
            },
            "storeAs": "whisperSpec"
          },
          {
            "tool": "memory_search",
            "params": {
              "query": "AISMR maximum hands count specification",
              "project": "aismr",
              "limit": 5
            },
            "storeAs": "handsSpec"
          },
          {
            "tool": "memory_search",
            "params": {
              "query": "AISMR no music audio specification",
              "project": "aismr",
              "limit": 5
            },
            "storeAs": "audioSpec"
          }
        ]
      },
      {
        "id": "remember_quality_issues",
        "step": 2,
        "type": "mcp_call",
        "description": "Retrieve past quality issues from episodic memory",
        "dependsOn": ["load_specs"],
        "mcp_call": {
          "tool": "memory_search",
          "params": {
            "query": "past AISMR screenplay quality issues timing errors validation failures",
            "memoryTypes": ["episodic"],
            "project": "aismr",
            "limit": 20
          },
          "storeAs": "qualityIssues"
        }
      },
      {
        "id": "search_successful_patterns",
        "step": 3,
        "type": "mcp_call",
        "description": "Search for successful screenplay patterns using hybrid search with graph expansion",
        "dependsOn": ["remember_quality_issues"],
        "mcp_call": {
          "tool": "memory_search",
          "params": {
            "query": "successful AISMR screenplay patterns tactile details timestamps",
            "project": "aismr",
            "memoryTypes": ["procedural"],
            "expandGraph": true,
            "maxHops": 2,
            "temporalBoost": true,
            "limit": 30
          },
          "storeAs": "successfulPatterns"
        }
      },
      {
        "id": "generate_screenplay",
        "step": 4,
        "type": "llm_generation",
        "description": "Generate screenplay with precise timing, tactile details, and compliance",
        "dependsOn": ["load_specs", "remember_quality_issues", "search_successful_patterns"],
        "llm_generation": {
          "model": "gpt-4",
          "prompt": "Generate an AISMR screenplay based on this selected idea: ${context.selectedIdea}. Requirements: Runtime must be exactly 8.0 seconds. Whisper audio must start at exactly 3.0 seconds. Maximum 2 hands visible. No background music. Include detailed tactile descriptions, timestamps for each action, and ensure compliance with these specs: ${runtimeSpec}, ${whisperSpec}, ${handsSpec}, ${audioSpec}. Avoid these past quality issues: ${qualityIssues}. Use these successful patterns: ${successfulPatterns}.",
          "schema": {
            "type": "object",
            "properties": {
              "prompt": {
                "type": "string",
                "description": "Full screenplay with timestamps and tactile details"
              },
              "timestamps": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "time": { "type": "number" },
                    "action": { "type": "string" },
                    "tactile_detail": { "type": "string" }
                  }
                }
              },
              "compliance_notes": {
                "type": "object",
                "properties": {
                  "runtime": { "type": "number" },
                  "whisper_timing": { "type": "number" },
                  "hands_count": { "type": "number" },
                  "music": { "type": "boolean" }
                }
              }
            },
            "required": ["prompt", "timestamps", "compliance_notes"]
          },
          "structuredOutput": true,
          "storeAs": "screenplay",
          "temperature": 0.7
        }
      },
      {
        "id": "validate_timing",
        "step": 5,
        "type": "validation",
        "description": "Validate timing requirements (8.0s runtime, 3.0s whisper)",
        "dependsOn": ["generate_screenplay"],
        "validation": {
          "timing": {
            "runtime": 8.0,
            "whisperTiming": 3.0,
            "maxHands": 2,
            "onViolation": "halt"
          }
        }
      },
      {
        "id": "validate_no_music",
        "step": 6,
        "type": "validation",
        "description": "Validate no music requirement",
        "dependsOn": ["validate_timing"],
        "validation": {
          "contentFilter": {
            "forbiddenTerms": ["music", "background music", "soundtrack", "song"],
            "onViolation": "halt"
          }
        }
      },
      {
        "id": "store_result",
        "step": 7,
        "type": "mcp_call",
        "description": "Store screenplay and validation results in episodic memory",
        "dependsOn": ["generate_screenplay", "validate_timing", "validate_no_music"],
        "mcp_call": {
          "tool": "memory_store",
          "params": {
            "content": "Generated AISMR screenplay: ${screenplay.prompt}",
            "memoryType": "episodic",
            "project": ["aismr"],
            "tags": ["aismr", "screenplay", "workflow-output"],
            "metadata": {
              "stage": "screenplay",
              "workflowRunId": "${context.workflowRunId}",
              "validationSummary": {
                "runtime": "${screenplay.compliance_notes.runtime}",
                "whisperTiming": "${screenplay.compliance_notes.whisper_timing}",
                "handsCount": "${screenplay.compliance_notes.hands_count}",
                "music": "${screenplay.compliance_notes.music}"
              }
            }
          }
        }
      }
    ],
    "output_format": {
      "type": "object",
      "properties": {
        "prompt": { "type": "string" },
        "timestamps": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "time": { "type": "number" },
              "action": { "type": "string" },
              "tactile_detail": { "type": "string" }
            }
          }
        },
        "compliance_notes": {
          "type": "object",
          "properties": {
            "runtime": { "type": "number" },
            "whisper_timing": { "type": "number" },
            "hands_count": { "type": "number" },
            "music": { "type": "boolean" }
          }
        },
        "validationSummary": {
          "type": "object",
          "properties": {
            "passed": { "type": "boolean" },
            "checks": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "check": { "type": "string" },
                  "passed": { "type": "boolean" }
                }
              }
            }
          }
        }
      }
    },
    "guardrails": [
      {
        "type": "timing",
        "rule": {
          "name": "runtime_must_be_8s",
          "rule": {
            "runtime": 8.0,
            "whisperTiming": 3.0,
            "maxHands": 2
          }
        },
        "onViolation": "halt"
      },
      {
        "type": "content_filter",
        "rule": {
          "name": "no_music",
          "rule": {
            "forbiddenTerms": ["music", "background music", "soundtrack"]
          }
        },
        "onViolation": "halt"
      }
    ]
  }
}

