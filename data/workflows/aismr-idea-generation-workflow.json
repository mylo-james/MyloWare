{
  "title": "AISMR Idea Generation Workflow",
  "memoryType": "procedural",
  "project": ["aismr"],
  "persona": ["ideagenerator"],
  "version": "1.0.0",
  "workflow": {
    "name": "Generate Ideas",
    "description": "Generate 12 unique AISMR video ideas with uniqueness validation against past ideas and archive",
    "steps": [
      {
        "id": "remember_past_ideas",
        "step": 1,
        "type": "mcp_call",
        "description": "Retrieve past ideas from episodic memory to avoid duplicates",
        "mcp_call": {
          "tool": "memory_search",
          "params": {
            "sessionId": "${context.sessionId}",
            "query": "past AISMR ideas generated",
            "limit": 50,
            "format": "bullets"
          },
          "storeAs": "pastIdeas"
        }
      },
      {
        "id": "search_archive",
        "step": 2,
        "type": "mcp_call",
        "description": "Search archive for similar ideas using keyword search",
        "mcp_call": {
          "tool": "memory_search",
          "params": {
            "query": "${context.userInput}",
            "project": "aismr",
            "searchMode": "keyword",
            "limit": 20
          },
          "storeAs": "archiveResults"
        }
      },
      {
        "id": "search_inspiration",
        "step": 3,
        "type": "mcp_call",
        "description": "Search for inspiration patterns using hybrid search with graph expansion",
        "dependsOn": ["search_archive"],
        "mcp_call": {
          "tool": "memory_search",
          "params": {
            "query": "${context.userInput}",
            "project": "aismr",
            "searchMode": "hybrid",
            "expandGraph": true,
            "maxHops": 2,
            "temporalBoost": true,
            "limit": 30
          },
          "storeAs": "inspirationResults"
        }
      },
      {
        "id": "generate_ideas",
        "step": 4,
        "type": "llm_generation",
        "description": "Generate 12 unique AISMR ideas using LLM with structured output",
        "dependsOn": ["remember_past_ideas", "search_archive", "search_inspiration"],
        "llm_generation": {
          "model": "gpt-4",
          "prompt": "Generate exactly 12 unique AISMR video ideas about ${context.userInput}. Each idea must be in Title Case descriptor + singular object format (two words). For each idea, provide a 2-4 sentence vibe covering emotion, hook, texture, feasibility, replay value, and environment potential. Exclude any ideas similar to these past ideas: ${pastIdeas}. Use these patterns for inspiration: ${inspirationResults}.",
          "schema": {
            "type": "object",
            "properties": {
              "userIdea": {
                "type": "string",
                "description": "Normalized base object (lowercase singular) applied to every idea"
              },
              "ideas": {
                "type": "array",
                "description": "Exactly 12 unique AISMR-ready concepts in Title Case descriptor + singular object format",
                "items": {
                  "type": "object",
                  "properties": {
                    "idea": {
                      "type": "string",
                      "description": "Title Case descriptor + singular object (two words, descriptor is one word)"
                    },
                    "vibe": {
                      "type": "string",
                      "description": "2-4 sentence explanation covering emotion, hook, texture, feasibility, replay value, and environment potential"
                    }
                  },
                  "required": ["idea", "vibe"],
                  "additionalProperties": false
                },
                "minItems": 12,
                "maxItems": 12
              }
            },
            "required": ["userIdea", "ideas"],
            "additionalProperties": false
          },
          "structuredOutput": true,
          "storeAs": "generatedIdeas",
          "temperature": 0.8
        },
        "validation": {
          "schema": {
            "schema": {
              "type": "object",
              "properties": {
                "userIdea": { "type": "string" },
                "ideas": {
                  "type": "array",
                  "minItems": 12,
                  "maxItems": 12
                }
              },
              "required": ["userIdea", "ideas"]
            },
            "onViolation": "halt"
          },
          "uniqueness": {
            "against": ["${pastIdeas}", "${archiveResults.results}"],
            "threshold": 0.7,
            "onViolation": "halt"
          }
        }
      },
      {
        "id": "uniqueness_audit",
        "step": 5,
        "type": "validation",
        "description": "Perform final uniqueness audit against all sources",
        "dependsOn": ["generate_ideas"],
        "validation": {
          "uniqueness": {
            "against": ["${pastIdeas}", "${archiveResults.results}", "${generatedIdeas.ideas}"],
            "threshold": 0.7,
            "onViolation": "halt"
          }
        }
      },
      {
        "id": "store_result",
        "step": 6,
        "type": "mcp_call",
        "description": "Store generated ideas and audit results in episodic memory",
        "dependsOn": ["generate_ideas", "uniqueness_audit"],
        "mcp_call": {
          "tool": "memory_store",
          "params": {
            "sessionId": "${context.sessionId}",
            "role": "assistant",
            "content": "Generated 12 unique AISMR ideas: ${generatedIdeas}",
            "tags": ["aismr", "idea-generation", "workflow-output"],
            "embeddingText": "AISMR ideas: ${generatedIdeas.ideas.map(i => i.idea).join(', ')}",
            "metadata": {
              "stage": "idea_generation",
              "workflowRunId": "${context.workflowRunId}",
              "totalIdeas": "${generatedIdeas.ideas.length}",
              "userIdea": "${generatedIdeas.userIdea}"
            }
          }
        }
      }
    ],
    "output_format": {
      "type": "object",
      "properties": {
        "userIdea": { "type": "string" },
        "ideas": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "idea": { "type": "string" },
              "vibe": { "type": "string" }
            }
          }
        },
        "uniquenessAudit": {
          "type": "object",
          "properties": {
            "passed": { "type": "boolean" },
            "checkedAgainst": { "type": "number" },
            "similarityScores": { "type": "array" }
          }
        }
      }
    },
    "guardrails": [
      {
        "type": "schema",
        "rule": {
          "name": "exact_12_ideas",
          "rule": {
            "type": "object",
            "properties": {
              "ideas": {
                "type": "array",
                "minItems": 12,
                "maxItems": 12
              }
            }
          }
        },
        "onViolation": "halt"
      },
      {
        "type": "uniqueness",
        "rule": {
          "name": "no_duplicate_ideas",
          "rule": {
            "threshold": 0.7
          }
        },
        "onViolation": "halt"
      }
    ]
  }
}

