{
  "name": "mcp-prompts",
  "version": "2.0.0",
  "description": "Agentic RAG system with semantic workflow discovery",
  "main": "dist/server.js",
  "type": "module",
  "scripts": {
    "mw": "tsx scripts/mw.ts",
    "dev": "NODE_ENV=development tsx watch src/server.ts",
    "dev:local": "NODE_ENV=development tsx watch --clear-screen=false src/server.ts",
    "dev:services:start": "docker compose up -d postgres n8n",
    "dev:services:stop": "docker compose down",
    "dev:services:logs": "docker compose logs -f postgres n8n",
    "workflow:dev:refresh": "npm run import:workflows:dev && npm run n8n:dev activate-all",
    "workflow:dev:summary": "tsx scripts/dev/print-dev-summary.ts",
    "workflow:dev:watch": "tsx scripts/dev/watch-workflows.ts",
    "dev:obs": "bash scripts/dev/obs.sh",
    "dev:validate": "bash scripts/dev/validate-dev-env.sh",
    "build": "tsc --project tsconfig.json",
    "build:watch": "tsc --project tsconfig.json --watch",
    "start": "node dist/server.js",
    "start:prod": "NODE_ENV=production node dist/server.js",
    "env:test": "bash scripts/env/env-manager.sh test",
    "env:dev": "bash scripts/env/env-manager.sh dev",
    "env:prod": "bash scripts/env/env-manager.sh prod",
    "env:use-test": "ln -sf .env.test .env && echo 'Switched to test environment'",
    "env:use-dev": "ln -sf .env.dev .env && echo 'Switched to dev environment'",
    "env:use-prod": "ln -sf .env.prod .env && echo 'Switched to prod environment'",
    "workflow:test": "NODE_ENV=test tsx scripts/test/run-workflow-test.ts",
    "workflow:test:dev": "N8N_WEBHOOK_URL=http://localhost:5678 tsx scripts/test/run-workflow-test.ts",
    "watch:execution": "tsx scripts/workflows/watch-execution.ts",
    "watch:latest": "tsx scripts/workflows/watch-execution.ts latest",
    "n8n:dev": "bash scripts/n8n/n8n-cli.sh dev",
    "n8n:test": "bash scripts/n8n/n8n-cli.sh test",
    "n8n:prod": "bash scripts/n8n/n8n-cli.sh prod",
    "type-check": "tsc --noEmit",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check:legacy-tools": "tsx scripts/validate/check-deprecated-tools.ts",
    "test": "NODE_ENV=test TEST_DB_USE_CONTAINER=1 vitest run",
    "test:unit": "NODE_ENV=test TEST_DB_USE_CONTAINER=1 vitest run --dir tests/unit",
    "test:unit:watch": "NODE_ENV=test TEST_DB_USE_CONTAINER=1 vitest --dir tests/unit",
    "test:integration": "NODE_ENV=test vitest run --dir tests/integration",
    "test:e2e": "NODE_ENV=test vitest run --dir tests/e2e",
    "test:e2e:live": "NODE_ENV=test TEST_LIVE_SERVICES=1 vitest run --dir tests/e2e",
    "test:perf": "NODE_ENV=test vitest run --dir tests/performance",
    "test:watch": "NODE_ENV=test TEST_DB_USE_CONTAINER=1 vitest",
    "test:coverage": "NODE_ENV=test TEST_DB_USE_CONTAINER=1 vitest run --coverage",
    "test:env:start": "docker compose --profile test up -d && sleep 5 && npm run import:workflows:test",
    "test:env:stop": "docker compose --profile test down",
    "test:env:reset": "docker compose --profile test down -v && npm run test:env:start",
    "test:env:logs": "docker compose --profile test logs -f",
    "db:reset": "tsx scripts/db/reset.ts",
    "db:bootstrap": "tsx scripts/db/bootstrap.ts",
    "db:migrate": "drizzle-kit push",
    "db:seed": "tsx scripts/db/seed.ts",
    "db:test:rollback": "tsx scripts/db/test-rollback.ts",
    "db:setup:test": "tsx scripts/db/setup-test-db.ts",
    "db:seed:test": "tsx scripts/db/seed-test.ts",
    "db:seed:workflows": "tsx scripts/db/seed-workflows.ts",
    "db:status": "drizzle-kit check:pg",
    "migrate:personas": "tsx scripts/migrate/personas.ts",
    "migrate:projects": "tsx scripts/migrate/projects.ts",
    "migrate:workflows": "tsx scripts/migrate/workflows.ts",
    "migrate:all": "npm run migrate:personas && npm run migrate:projects && npm run migrate:workflows",
    "ingest-data": "tsx scripts/ingest/ingest-data.ts",
    "ingest-data:dry-run": "tsx scripts/ingest/ingest-data.ts --dry-run",
    "test:mcp": "tsx scripts/test/test-mcp-tools.ts",
    "workflows:pull": "tsx scripts/workflows/workflows-pull.ts",
    "workflows:pull:dev": "N8N_BASE_URL=http://localhost:5678 tsx scripts/workflows/workflows-pull.ts",
    "workflows:pull:test": "N8N_BASE_URL=http://localhost:5679 N8N_API_KEY=test-api-key tsx scripts/workflows/workflows-pull.ts",
    "workflows:push": "npm run import:workflows",
    "workflows:push:dev": "npm run import:workflows:dev",
    "workflows:push:test": "npm run import:workflows:test",
    "workflows:push:prod": "npm run import:workflows:prod",
    "import:workflows": "tsx scripts/workflows/import-workflows.ts",
    "import:workflows:dev": "N8N_BASE_URL=http://localhost:5678 tsx scripts/workflows/import-workflows.ts",
    "import:workflows:test": "N8N_BASE_URL=http://localhost:5679 N8N_API_KEY=test-api-key tsx scripts/workflows/import-workflows.ts",
    "import:workflows:prod": "tsx scripts/workflows/import-workflows.ts",
    "register:workflows": "tsx scripts/workflows/register-workflow-mappings.ts",
    "sync:n8n-ids": "tsx scripts/workflows/sync-n8n-workflow-ids.ts",
    "validate:n8n-ids": "tsx scripts/workflows/validate-workflow-ids.ts",
    "docs:generate": "tsx scripts/docs/generate-docs.ts",
    "docs:generate:tools": "tsx scripts/docs/generate-docs.ts --tools",
    "docs:generate:schema": "tsx scripts/docs/generate-docs.ts --schema",
    "docs:check-links": "tsx scripts/docs/check-docs-links.ts"
  },
  "dependencies": {
    "@fastify/cors": "^11.1.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/rate-limit": "^10.3.0",
    "@modelcontextprotocol/sdk": "^1.20.2",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.44.7",
    "fastify": "^5.6.1",
    "openai": "^6.7.0",
    "pg": "^8.16.3",
    "pgvector": "^0.2.1",
    "pino": "^10.1.0",
    "prom-client": "^15.1.3",
    "zod": "^3.25.76",
    "zod-to-json-schema": "^3.24.6"
  },
  "devDependencies": {
    "@types/node": "^24.9.2",
    "@types/pg": "^8.15.6",
    "@typescript-eslint/eslint-plugin": "^8.46.2",
    "@typescript-eslint/parser": "^8.46.2",
    "@vitest/coverage-v8": "^4.0.4",
    "drizzle-kit": "^0.31.6",
    "eslint": "^9.38.0",
    "eslint-config-prettier": "^10.1.8",
    "pino-pretty": "^11.0.0",
    "prettier": "^3.6.2",
    "testcontainers": "^11.8.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^4.0.4"
  }
}
