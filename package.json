{
  "name": "mcp-prompts",
  "version": "2.0.0",
  "description": "Agentic RAG system with semantic workflow discovery",
  "main": "dist/server.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "dev:local": "tsx watch --clear-screen=false src/server.ts",
    "dev:docker": "docker compose --profile dev up --build",
    "dev:docker:logs": "docker compose logs -f mcp-server-dev",
    "dev:stop": "docker compose --profile dev down",
    "build": "tsc --project tsconfig.json",
    "build:watch": "tsc --project tsconfig.json --watch",
    "start": "node dist/server.js",
    "start:prod": "NODE_ENV=production node dist/server.js",
    "type-check": "tsc --noEmit",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:unit": "vitest run --dir tests/unit",
    "test:unit:local": "bash -lc \"TEST_DB_URL=\\\"${TEST_DB_URL:-postgresql://mcp_test:test@127.0.0.1:6543/mcp_v2_test}\\\" LOG_LEVEL=${LOG_LEVEL:-warn} vitest run --dir tests/unit\"",
    "test:unit:container": "bash -lc \"TEST_DB_USE_CONTAINER=1 LOG_LEVEL=${LOG_LEVEL:-warn} vitest run --dir tests/unit\"",
    "test:integration": "vitest run --dir tests/integration",
    "test:e2e": "vitest run --dir tests/e2e",
    "test:perf": "vitest run --dir tests/performance",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "db:reset": "tsx scripts/db/reset.ts",
    "db:bootstrap": "tsx scripts/db/bootstrap.ts",
    "db:migrate": "drizzle-kit push",
    "db:seed": "tsx scripts/db/seed.ts",
    "db:setup:test": "tsx scripts/db/setup-test-db.ts",
    "db:seed:test": "tsx scripts/db/seed-test.ts",
    "db:seed:workflows": "tsx scripts/db/seed-workflows.ts",
    "db:status": "drizzle-kit check:pg",
    "migrate:personas": "tsx scripts/migrate/personas.ts",
    "migrate:projects": "tsx scripts/migrate/projects.ts",
    "migrate:workflows": "tsx scripts/migrate/workflows.ts",
    "migrate:all": "npm run migrate:personas && npm run migrate:projects && npm run migrate:workflows",
    "test:mcp": "tsx scripts/test-mcp-tools.ts",
    "import:workflows": "tsx scripts/import-workflows.ts"
  },
  "dependencies": {
    "@fastify/cors": "^11.1.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/rate-limit": "^10.3.0",
    "@modelcontextprotocol/sdk": "^1.20.2",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.44.7",
    "fastify": "^5.6.1",
    "openai": "^6.7.0",
    "pg": "^8.16.3",
    "pgvector": "^0.2.1",
    "pino": "^10.1.0",
    "prom-client": "^15.1.3",
    "zod": "^3.25.76",
    "zod-to-json-schema": "^3.24.6"
  },
  "devDependencies": {
    "@types/node": "^24.9.2",
    "@types/pg": "^8.15.6",
    "@typescript-eslint/eslint-plugin": "^8.46.2",
    "@typescript-eslint/parser": "^8.46.2",
    "@vitest/coverage-v8": "^4.0.4",
    "drizzle-kit": "^0.31.6",
    "eslint": "^9.38.0",
    "eslint-config-prettier": "^10.1.8",
    "pino-pretty": "^11.0.0",
    "prettier": "^3.6.2",
    "testcontainers": "^11.8.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^4.0.4"
  }
}
