      },
      {
        "parameters": {
          "jsCode": "const raw = $json ?? {};\nconst userInput = typeof raw.userInput === 'string' && raw.userInput.trim().length > 0\n  ? raw.userInput.trim()\n  : '';\nif (!userInput) {\n  throw new Error('AISMR workflow requires a non-empty userInput.');\n}\nconst chatId = typeof raw.chatId === 'string' && raw.chatId.trim().length > 0\n  ? raw.chatId.trim()\n  : null;\nconst project = {\n  id: 'a372acc6-5b6a-46c5-835d-6e9859d5055c',\n  slug: 'aismr',\n  name: 'AISMR'\n};\nconst requestId = `aismr-${Date.now()}-${Math.random().toString(36).slice(2, 8)}`;\nreturn {\n  json: {\n    userInput,\n    chatId,\n    project,\n    requestId,\n    timestamps: {\n      receivedAt: new Date().toISOString()\n    }\n  }\n};"
        },
        "type": "n8n-nodes-base.code",
        "typeVersion": 2,
        "position": [
          -288,
          208
        ],
        "id": "3a7c18db-7fe1-4a8e-aaf6-95736c611ad6",
        "name": "Normalize Request"
      },
      {
        "parameters": {
          "method": "POST",
          "url": "https://mcp-vector.mjames.dev/api/runs",
          "authentication": "genericCredentialType",
          "genericAuthType": "httpHeaderAuth",
          "sendBody": true,
          "specifyBody": "json",
          "jsonBody": "={{ { projectId: $('Normalize Request').item.json.project.id, chatId: $('Normalize Request').item.json.chatId ?? null, input: { userInput: $('Normalize Request').item.json.userInput }, metadata: { projectSlug: $('Normalize Request').item.json.project.slug, requestId: $('Normalize Request').item.json.requestId, source: 'aismr.workflow' } } }}",
          "options": {}
        },
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 4.2,
