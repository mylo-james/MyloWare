          -64,
          208
        ],
        "id": "783f1b96-21af-4228-ae7f-5fd9f29f6a1c",
        "name": "Create Run",
        "credentials": {
          "httpHeaderAuth": {
            "id": "PDRTlQZsKzQBcv6T",
            "name": "Mylo MCP"
          }
        }
      },
      {
        "parameters": {
          "jsCode": "const request = $('Normalize Request').item.json;\nconst runResponse = $('Create Run').item.json;\nconst run = runResponse?.data?.run ?? runResponse?.run ?? runResponse;\nif (!run || !run.id) {\n  throw new Error('Unable to determine run id from Create Run response.');\n}\nconst outputSchema = JSON.stringify({\n  type: 'object',\n  properties: {\n    userIdea: {\n      type: 'string',\n      description: 'Normalized base object (lowercase singular) applied to every idea.'\n    },\n    ideas: {\n      type: 'array',\n      minItems: 12,\n      maxItems: 12,\n      items: {\n        type: 'object',\n        properties: {\n          idea: {\n            type: 'string',\n            description: 'Title Case descriptor + singular object (two words, descriptor is one word).'\n          },\n          vibe: {\n            type: 'string',\n            description: '2-4 sentence explanation covering emotion, hook, texture, feasibility, replay value, and environment potential.'\n          }\n        },\n        required: ['idea', 'vibe'],\n        additionalProperties: false\n      }\n    }\n  },\n  required: ['userIdea', 'ideas'],\n  additionalProperties: false\n});\nreturn {\n  json: {\n    persona: 'ideagenerator',\n    project: request.project.slug,\n    projectId: request.project.id,\n    chatInput: request.userInput,\n    chatId: request.chatId ?? null,\n    runId: run.id,\n    run,\n    outputSchema,\n    request\n  }\n};"
        },
        "type": "n8n-nodes-base.code",
        "typeVersion": 2,
        "position": [
          160,
