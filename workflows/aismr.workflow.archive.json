        "parameters": {
          "jsCode": "const raw = $json ?? {};\nconst ideas = raw.ideas ?? raw.output ?? raw.result ?? raw;\nif (!Array.isArray(ideas) || ideas.length === 0) {\n  throw new Error('Expected at least one idea from Generate Ideas workflow.');\n}\nreturn {\n  json: {\n    ideas\n  }\n};"
