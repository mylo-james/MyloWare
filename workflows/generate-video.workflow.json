        "mode": "runOnceForAllItems",
        "language": "javaScript",
        "jsCode": "const trigger = $('When Called').item?.json ?? {};\nconst item = $input.item;\nconst payload = item.json || {};\nconst trace = trigger.trace || payload.trace || {};\nconst personaNameRaw = trigger.callerPersona ?? trigger.personaName ?? trigger.persona ?? payload.callerPersona ?? payload.personaName ?? payload.persona ?? trace.currentOwner ?? '';\nconst personaName = String(personaNameRaw).toLowerCase();\nconst owner = personaNameRaw || 'unknown';\nconst traceId = trigger.traceId ?? payload.traceId ?? trace.traceId ?? '';\nif (personaName !== 'veo') {\n  const traceNote = traceId ? ` (trace ${traceId})` : '';\n  throw new Error(`Generate Video workflow is restricted to Veo. Current owner: ${owner}${traceNote}. Hand off to Veo instead of calling this tool.`);\n}\nreturn $input.all();"
