      "name": "When Called"
    },
    {
      "parameters": {
        "jsCode": "const slugify = (value) => {\n  if (value === undefined || value === null) {\n    return null;\n  }\n  const text = String(value).trim().toLowerCase();\n  if (!text) {\n    return null;\n  }\n  const hyphenated = text.replace(/\\s+/g, '-');\n  const cleaned = hyphenated.replace(/[^a-z0-9-]/g, '');\n  const collapsed = cleaned.replace(/-+/g, '-').replace(/^-+|-+$/g, '');\n  return collapsed.length > 0 ? collapsed : null;\n};\n\nconst personaSlug = slugify($json.personaSlug ?? $json.personaId ?? $json.persona);\nconst projectSlug = slugify($json.projectSlug ?? $json.project);\nconst runId = $json.runId ?? null;\n\nif (!personaSlug) {\n  throw new Error('personaSlug is required for Load Persona.');\n}\n\nreturn [{ json: { personaSlug, projectSlug, runId } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        128,
        16
      ],
      "id": "38975401-7504-4c41-ba10-7ea2ab802b4f",
      "name": "Normalize Inputs"
    },
    {
      "parameters": {
        "url": "={{ (function() { const params = []; if ($json.projectSlug) { params.push('project=' + encodeURIComponent($json.projectSlug)); } if ($json.personaSlug) { params.push('persona=' + encodeURIComponent($json.personaSlug)); } return 'https://mcp-vector.mjames.dev/api/prompts/resolve?' + params.join('&'); })() }}",
        "options": {}
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        352,
        16
      ],
      "id": "987523d0-8925-4376-8d21-30e76e877369",
      "name": "Resolve Prompt"
    },
    {
      "parameters": {
        "jsCode": "const response = $json ?? {};\nconst data = response.data ?? {};\nconst prompt = data.prompt;\nconst resolution = data.resolution ?? null;\nconst candidates = data.candidates ?? [];\nif (!prompt || !prompt.content) {\n  const message = response.error?.message ?? 'Prompt could not be resolved.';\n  throw new Error(message);\n}\nconst context = $('Normalize Inputs').first().json;\nreturn [{\n  json: {\n    prompt_text: prompt.content,\n    system_prompt: prompt.content,\n    prompt_key: prompt.promptKey ?? null,\n    prompt_metadata: prompt.metadata ?? {},\n    resolution,\n    candidates,\n    persona_slug: context.personaSlug,\n    project_slug: context.projectSlug ?? null\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
