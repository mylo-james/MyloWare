        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ (() => {\n  const run = $('Get Run').item?.json ?? {};\n  const stages = run.stages ?? {};\n  const clone = (value) => (value && typeof value === 'object' ? { ...value } : {});\n  const ideaStage = clone(stages.idea_generation);\n  if (!ideaStage.status) { ideaStage.status = 'completed'; }\n  const screenplayStage = { ...clone(stages.screenplay), status: 'completed', output: $json.output ?? {} };\n  const videoStage = { ...clone(stages.video_generation), status: 'running' };\n  const publishingStage = clone(stages.publishing);\n  if (!publishingStage.status) { publishingStage.status = 'pending'; }\n\n  const mergedOutput = { ...(run.output ?? {}), screenplay: $json.output ?? {} };\n\n  return {\n    status: 'running',\n    currentStage: 'video_generation',\n    stages: {\n      idea_generation: ideaStage,\n      screenplay: screenplayStage,\n      video_generation: videoStage,\n      publishing: publishingStage\n    },\n    output: mergedOutput\n  };\n})() }}",
        "options": {}
      },
