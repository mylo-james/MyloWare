      "parameters": {
        "jsCode": "// Extract chatId and user input from turn\nconst turnResponse = $('Get Turn').item?.json ?? {};\nconst turn = turnResponse.data?.turn ?? turnResponse.turn ?? turnResponse;\nif (!turn || typeof turn !== 'object') {\n  throw new Error('AISMR workflow could not load conversation turn details.');\n}\nconst turnContent = typeof turn.content === 'string' ? turn.content.trim() : '';\nif (!turnContent) {\n  throw new Error('AISMR workflow could not find user turn content.');\n}\nconst chatId = turn.metadata?.chatId ?? turn.metadata?.telegramChatId ?? null;\nif (!chatId) {\n  console.warn('No chatId found in turn metadata - progress updates will fail');\n}\n\nreturn {\n  json: {\n    chatId,\n    userInput: turnContent,\n    turn,\n    turnId: turn.id ?? $('When Executed by Another Workflow').item?.json?.turnId ?? $json.turnId\n  }\n};"
      },
