    {
      "parameters": {
        "jsCode": "// Store runId in execution custom data for error handler\nconst runResponse = $json ?? {};\nconst workflowRun = runResponse.workflowRun ?? runResponse.data?.workflowRun ?? runResponse;\nconst runId = workflowRun?.id;\n\nif (runId) {\n  $execution.customData.set('runId', runId);\n}\n\nreturn {\n  json: {\n    ...runResponse,\n    workflowRun,\n    runId\n  }\n};"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        224,
        64
      ],
      "id": "9119cb8c-7560-49d5-8e5d-9c5e7c90a21e",
      "name": "Store RunId"
    },
    {
      "parameters": {},
      "type": "n8n-nodes-base.errorTrigger",
      "typeVersion": 1,
      "position": [
        -672,
        -256
      ],
      "id": "153fa465-d283-44e6-a75c-3d69f46b4ed6",
      "name": "On Error"
    },
    {
      "parameters": {
        "jsCode": "// Try to extract runId and chatId from various sources\nconst errorData = $json ?? {};\nconst execution = errorData.execution ?? {};\n\n// Try to get runId from execution custom data\nlet runId = $execution.customData?.get('runId');\nlet chatId = null;\n\n// If not found, try to extract from Create Run node if it executed\nif (!runId) {\n  try {\n    const createRunResponse = $('Create Run').item?.json ?? {};\n    runId = createRunResponse.workflowRun?.id ??\n      createRunResponse.data?.workflowRun?.id ??\n      createRunResponse.data?.run?.id ??\n      createRunResponse.run?.id ??\n      createRunResponse.id;\n  } catch (e) {\n    // Node may not have executed\n  }\n}\n\n// Try to get chatId from Extract ChatId node if it executed\nif (!chatId) {\n  try {\n    const chatData = $('Extract ChatId').item?.json ?? {};\n    chatId = chatData.chatId;\n  } catch (e) {\n    // Node may not have executed\n  }\n}\n\n// Try to get chatId from Get Turn node if it executed\nif (!chatId) {\n  try {\n    const turnResponse = $('Get Turn').item?.json ?? {};\n    const turn = turnResponse.data?.turn ?? turnResponse.turn ?? turnResponse;\n    chatId = turn?.metadata?.chatId ?? turn?.metadata?.telegramChatId;\n  } catch (e) {\n    // Node may not have executed\n  }\n}\n\n// If still not found, try to get from Assemble Context if it executed\nif (!runId || !chatId) {\n  try {\n    const context = $('Assemble Context').item?.json ?? {};\n    if (!runId) runId = context.runId;\n    if (!chatId) chatId = context.chatId;\n  } catch (e) {\n    // Node may not have executed\n  }\n}\n\n// Extract error message\nconst errorMessage = execution.error?.message ?? errorData.error?.message ?? 'Unknown error in AISMR workflow';\nconst errorStack = execution.error?.stack ?? errorData.error?.stack ?? '';\n\nreturn {\n  json: {\n    runId,\n    chatId,\n    errorMessage,\n    errorStack,\n    executionId: execution.id ?? null,\n    lastNodeExecuted: execution.lastNodeExecuted ?? null,\n    errorData\n  }\n};"
      },
