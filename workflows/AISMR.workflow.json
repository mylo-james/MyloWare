      "parameters": {
        "jsCode": "// Extract selected idea from Generate Ideas workflow output\nconst generateIdeasOutput = $('Call Generate Ideas').item.json;\n\nconst ideas = generateIdeasOutput.ideas || [];\nconst selectedIdea = generateIdeasOutput.selectedIdea || (ideas.length > 0 ? ideas[0] : null);\n\nlet videoId = null;\nif (selectedIdea) {\n  videoId = selectedIdea.videoId || selectedIdea.ideaId || null;\n} else if (ideas.length > 0) {\n  const firstIdea = ideas[0];\n  videoId = firstIdea.videoId || firstIdea.ideaId || null;\n}\n\nreturn {\n  json: {\n    selectedIdea,\n    selectedItem: selectedIdea?.ideaId || (ideas.length > 0 ? ideas[0]?.ideaId : null),\n    ideas,\n    videoId,\n    idea: selectedIdea || (ideas.length > 0 ? ideas[0] : null),\n    runId: $('Assemble Context').item.json.runId,\n    chatId: $('Assemble Context').item.json.chatId,\n    userInput: $('Assemble Context').item.json.userInput\n  }\n};"
