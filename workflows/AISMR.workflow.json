        "specifyBody": "json",
        "jsonBody": "={{ (() => {\n  const runPayload =\n    $json.workflowRun ??\n    $json.data?.workflowRun ??\n    $json.data?.run ??\n    $json.run ??\n    $json;\n\n  const stageOutput = runPayload?.stages?.idea_generation?.output ?? null;\n  const candidateIdeas = [\n    Array.isArray(stageOutput?.ideas) ? stageOutput.ideas : null,\n    Array.isArray(runPayload?.output?.ideas) ? runPayload.output.ideas : null,\n    Array.isArray(runPayload?.result) ? runPayload.result : null\n  ];\n  const ideas = candidateIdeas.find(Array.isArray) ?? [];\n\n  const userIdea =\n    runPayload?.input?.userIdea ??\n    runPayload?.input?.user_input ??\n    runPayload?.input?.userInput ??\n    runPayload?.metadata?.userIdea ??\n    '';\n\n  return ({\n    workflowRunId: $('Assemble Context').item.json.runId,\n    stage: 'idea_generation',\n    content: {\n      ideas,\n      userIdea,\n      totalIdeas: Array.isArray(ideas) ? ideas.length : 0\n    },\n    notifyChannels: ['slack']\n  });\n})() }}",
