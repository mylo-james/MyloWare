        "genericAuthType": "httpHeaderAuth",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ ({ projectId: 'aismr', sessionId: $('Get Turn').item.json?.data?.turn?.sessionId ?? $('Get Turn').item.json?.turn?.sessionId ?? $('Get Turn').item.json?.sessionId, input: { source: 'aismr_orchestrator', personaId: 'ideagenerator', turnId: $json.turnId, chatId: $('Extract ChatId').item?.json?.chatId ?? null, userInput: $('Extract ChatId').item?.json?.userInput ?? null, turn: $('Extract ChatId').item?.json?.turn ?? null }\n}) }}",
        "options": {
