    {
      "parameters": {
        "jsCode": "// Extract selected idea and video ID from HITL approval\nconst approval = $('Get Approval Status').item.json.approval ?? {};\nconst selectedItem = approval.content?.selectedItem ?? null;\n\nconst runResponse = $('Get Run After Ideas').item?.json ?? {};\nconst runPayload =\n  runResponse.workflowRun ??\n  runResponse.data?.workflowRun ??\n  runResponse.data?.run ??\n  runResponse.run ??\n  runResponse;\n\nconst stageOutput = runPayload?.stages?.idea_generation?.output ?? null;\nconst candidateIdeas = [\n  Array.isArray(stageOutput?.ideas) ? stageOutput.ideas : null,\n  Array.isArray(runPayload?.output?.ideas) ? runPayload.output.ideas : null,\n  Array.isArray(runPayload?.result) ? runPayload.result : null\n];\nconst ideas = candidateIdeas.find(Array.isArray) ?? [];\n\n// Find the selected idea in the ideas array\nlet selectedIdea = selectedItem;\nlet videoId = null;\n\nif (selectedItem && selectedItem.ideaId) {\n  videoId = selectedItem.ideaId;\n} else if (selectedItem && selectedItem.idea) {\n  // Find matching idea from the ideas array\n  const matching = ideas.find((idea) => idea.idea === selectedItem.idea);\n  if (matching && matching.ideaId) {\n    videoId = matching.ideaId;\n    selectedIdea = matching;\n  }\n} else if (ideas.length > 0) {\n  // Fallback to first idea if no selection\n  selectedIdea = ideas[0];\n  videoId = selectedIdea.ideaId || selectedIdea.id;\n}\n\nreturn {\n  json: {\n    selectedIdea,\n    videoId,\n    runId: $('Assemble Context').item.json.runId,\n    chatId: $('Assemble Context').item.json.chatId,\n    userInput: $('Assemble Context').item.json.userInput\n  }\n};"
