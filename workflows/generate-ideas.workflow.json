    {
      "parameters": {
        "jsCode": "const payload = $json?.data?.run;\nif (!payload) {\n  throw new Error('Run payload missing from API response.');\n}\nconst normalized = {\n  ...payload,\n  project_id: payload.projectId ?? null,\n  persona_id: payload.personaId ?? null,\n  chat_id: payload.chatId ?? null,\n  result: payload.result ?? null,\n  started_at: payload.startedAt ?? null,\n  completed_at: payload.completedAt ?? null,\n  created_at: payload.createdAt ?? null,\n  updated_at: payload.updatedAt ?? null,\n  input: payload.input ?? {},\n  metadata: payload.metadata ?? {},\n};\nreturn [{ json: normalized }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        560,
        -128
      ],
      "id": "0ba93b9e-d12c-43f4-939f-634f7755c448",
      "name": "Get Run"
    },
    {
      "parameters": {
        "jsCode": "// Aggregate all ideas from the previous items\nconst ideas = [];\nconst workflowRunId = $('Get Run').item.json.run_id || $('Get Run').item.json.id || $('When Called').item.json.runId;\nconst projectId = $('Get Run').item.json.project_id || $('Get Run').item.json.projectId || 'aismr';\n\n// Collect all ideas from the split items\nfor (const item of $input.all()) {\n  if (item.json.idea) {\n    ideas.push({\n      idea: item.json.idea,\n      vibe: item.json.vibe,\n      ideaId: item.json.run_id || item.json.id,\n    });\n  }\n}\n\nreturn [{\n  json: {\n    workflowRunId,\n    projectId,\n    ideas,\n    userIdea: $('Get Run').item.json.user_idea || $('Get Run').item.json.userIdea || '',\n    totalIdeas: ideas.length,\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1672,
        -128
      ],
      "id": "aggregate-ideas-node",
      "name": "Aggregate Ideas"
