{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.mylo.ware/tool-description.schema.json",
  "title": "MyloWare Tool Description",
  "description": "Schema for describing tools that can be registered with the MyloWare orchestrator.",
  "type": "object",
  "additionalProperties": false,
  "required": ["tool"],
  "properties": {
    "tool": {
      "type": "object",
      "description": "Metadata, schemas, and guidance for a single tool.",
      "additionalProperties": false,
      "required": [
        "id",
        "name",
        "version",
        "description",
        "input_schema",
        "output_schema"
      ],
      "properties": {
        "id": {
          "type": "string",
          "description": "Stable fully-qualified identifier, e.g. namespace.tool_name.version.",
          "pattern": "^[a-z0-9_.-]+(\\.[a-z0-9_.-]+)*$"
        },
        "name": {
          "type": "string",
          "description": "Short name that agents will use when referring to the tool.",
          "pattern": "^[a-z0-9]+(?:[_.-][a-z0-9]+)*$"
        },
        "namespace": {
          "type": "string",
          "description": "Optional namespace grouping related tools (e.g. myloWare.crm)."
        },
        "version": {
          "type": "string",
          "description": "SemVer-compatible version string (e.g. 1.0.0)."
        },
        "description": {
          "type": "string",
          "description": "Concise but complete description of the tool's purpose, inputs, and outputs."
        },
        "one_liner": {
          "type": "string",
          "description": "Single sentence summary to display in quick reference views."
        },
        "invocation_context": {
          "type": "string",
          "description": "Guidance describing when this tool should or should not be invoked."
        },
        "agent_hint": {
          "type": "string",
          "description": "Optional hint that can be surfaced to agents when deciding between tools."
        },
        "pattern": {
          "type": "string",
          "description": "Classification of the tool role following Databricks patterns.",
          "enum": [
            "structured_data_retrieval",
            "unstructured_retrieval",
            "code_interpreter",
            "external_api",
            "action_execution",
            "knowledge_base",
            "reasoning_helper",
            "other"
          ]
        },
        "tags": {
          "type": "array",
          "description": "Keywords used for discovery and search.",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true,
          "default": []
        },
        "availability": {
          "type": "array",
          "description": "Environments where this tool is available (e.g. production, staging).",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "auth": {
          "type": "object",
          "description": "Authentication requirements for calling the tool.",
          "additionalProperties": false,
          "properties": {
            "required_scopes": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              },
              "uniqueItems": true
            },
            "policy_notes": {
              "type": "string",
              "description": "Human-readable notes about auth or policy caveats."
            }
          }
        },
        "constraints": {
          "type": "object",
          "description": "Operational limitations and guardrails for tool usage.",
          "additionalProperties": false,
          "properties": {
            "max_duration_seconds": {
              "type": "number",
              "minimum": 0
            },
            "rate_limit_per_minute": {
              "type": "number",
              "minimum": 0
            },
            "max_items": {
              "type": "integer",
              "minimum": 1
            },
            "note": {
              "type": "string",
              "description": "Free-form description of additional constraints."
            }
          }
        },
        "input_schema": {
          "type": "object",
          "description": "JSON Schema describing accepted inputs.",
          "additionalProperties": true
        },
        "output_schema": {
          "type": "object",
          "description": "JSON Schema describing the tool response.",
          "additionalProperties": true
        },
        "metrics": {
          "type": "object",
          "description": "Operational metrics or SLOs tracked for this tool.",
          "additionalProperties": false,
          "properties": {
            "success_rate": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "average_latency_ms": {
              "type": "number",
              "minimum": 0
            },
            "last_evaluated": {
              "type": "string",
              "format": "date"
            }
          }
        },
        "versioning": {
          "type": "object",
          "description": "Ownership and change-management metadata.",
          "additionalProperties": false,
          "properties": {
            "last_updated": {
              "type": "string",
              "format": "date"
            },
            "owner_team": {
              "type": "string"
            },
            "contact": {
              "type": "string",
              "description": "Email, Slack channel, or other contact for tool owners."
            },
            "deprecated": {
              "type": "boolean",
              "default": false
            },
            "replacement_tool": {
              "type": "string",
              "description": "Identifier of the replacement tool when deprecated is true."
            }
          }
        },
        "examples": {
          "type": "array",
          "description": "Illustrative examples of how to call the tool.",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "name": {
                "type": "string",
                "description": "Short label for the example."
              },
              "description": {
                "type": "string",
                "description": "What the example demonstrates."
              },
              "input": {},
              "output": {},
              "notes": {
                "type": "string"
              }
            },
            "required": ["input"]
          }
        }
      }
    }
  }
}

