{
  "title": "Podcast Clip Generator",
  "memory": {
    "promptType": "project",
    "type": "project",
    "persona": [],
    "project": ["podcast-clips"],
    "tags": ["project", "podcast", "clips", "extraction"]
  },
  "agent": {
    "name": "Podcast Clip Generator",
    "id": "podcast-clips",
    "title": "Podcast Clip Generator",
    "icon": "🎙️"
  },
  "workflow": {
    "taskDescription": "Extract and enhance engaging clips from podcast transcripts with clear hooks and complete thoughts",
    "outputSchema": {
      "type": "object",
      "properties": {
        "clips": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "start_time": {
                "type": "number",
                "description": "Start time in seconds"
              },
              "end_time": {
                "type": "number",
                "description": "End time in seconds"
              },
              "duration": {
                "type": "number",
                "description": "Clip duration in seconds"
              },
              "transcript": {
                "type": "string",
                "description": "Full transcript of the clip"
              },
              "hook": {
                "type": "string",
                "description": "Attention-grabbing hook for the clip"
              },
              "topic": {
                "type": "string",
                "description": "Main topic or theme"
              },
              "value_proposition": {
                "type": "string",
                "description": "What value this clip provides to viewers"
              }
            },
            "required": ["start_time", "end_time", "transcript", "hook"]
          },
          "minItems": 1,
          "maxItems": 10
        },
        "metadata": {
          "type": "object",
          "properties": {
            "episode_title": { "type": "string" },
            "episode_number": { "type": "number" },
            "speakers": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        }
      },
      "required": ["clips", "metadata"]
    },
    "guardrails": [
      {
        "type": "duration",
        "rule": {
          "name": "clip_duration",
          "rule": {
            "min": 30,
            "max": 90
          }
        },
        "onViolation": "halt"
      },
      {
        "type": "coherence",
        "rule": {
          "name": "complete_thoughts",
          "rule": {
            "ensure_complete_thought": true,
            "no_cutoff_sentences": true
          }
        },
        "onViolation": "halt"
      }
    ]
  },
  "generation_api": "https://api.clip-extractor.com/v1/extract",
  "generation_config": {
    "format": "mp4",
    "add_captions": true,
    "caption_style": "modern",
    "include_speaker_labels": true
  },
  "publishing_platforms": ["youtube", "tiktok", "instagram"],
  "evaluation_criteria": [
    "Hook strength",
    "Thought completeness",
    "Speaker clarity",
    "Value proposition",
    "Engagement potential"
  ]
}

