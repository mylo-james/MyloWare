{
  "title": "YouTube Shorts Generator",
  "memory": {
    "promptType": "project",
    "type": "project",
    "persona": [],
    "project": ["youtube-shorts"],
    "tags": ["project", "youtube", "shorts", "video"]
  },
  "agent": {
    "name": "YouTube Shorts Generator",
    "id": "youtube-shorts",
    "title": "YouTube Shorts Generator",
    "icon": "📺"
  },
  "workflow": {
    "taskDescription": "Generate engaging YouTube Shorts content with hooks, viral potential, and clear value proposition",
    "outputSchema": {
      "type": "object",
      "properties": {
        "title": {
          "type": "string",
          "maxLength": 100,
          "description": "Catchy title optimized for YouTube Shorts discovery"
        },
        "description": {
          "type": "string",
          "maxLength": 5000,
          "description": "Full description with keywords and call-to-action"
        },
        "tags": {
          "type": "array",
          "items": { "type": "string" },
          "maxItems": 15,
          "description": "Relevant tags for discoverability"
        },
        "hook": {
          "type": "string",
          "description": "First 3 seconds hook to capture attention"
        },
        "content": {
          "type": "string",
          "description": "Full script/content for the short"
        }
      },
      "required": ["title", "description", "hook", "content"]
    },
    "guardrails": [
      {
        "type": "duration",
        "rule": {
          "name": "shorts_duration",
          "rule": {
            "min": 15,
            "max": 60
          }
        },
        "onViolation": "halt"
      },
      {
        "type": "content_filter",
        "rule": {
          "name": "community_guidelines",
          "rule": {
            "forbiddenTerms": ["violence", "explicit", "hate speech"],
            "requiredTerms": []
          }
        },
        "onViolation": "halt"
      }
    ]
  },
  "generation_api": "https://api.shorts-generator.com/v1/generate",
  "generation_config": {
    "aspect_ratio": "9:16",
    "max_duration": 60,
    "min_duration": 15,
    "resolution": "1080x1920",
    "fps": 30
  },
  "publishing_platforms": ["youtube"],
  "evaluation_criteria": [
    "Hook quality (first 3 seconds)",
    "Value proposition clarity",
    "Engagement potential",
    "SEO optimization",
    "Viral potential"
  ]
}

