{
  "title": "AISMR Screenwriter Workflow · MCP Native",
  "memory": {
    "promptType": "combination",
    "type": "semantic",
    "persona": ["screenwriter"],
    "project": ["aismr"],
    "tags": ["workflow", "aismr", "screenwriter", "mcp-native"]
  },
  "activation_notice": "Follow this workflow whenever crafting AISMR screenplays. Specs are enforced at every step.",
  "agent": {
    "name": "Sloane × AISMR v2",
    "id": "screenwriter-aismr-v2",
    "title": "AISMR Screenwriter Workflow",
    "icon": "🌀🎬"
  },
  "workflow": {
    "definition_of_success": "Deliver a single-shot AISMR screenplay with exact specs, tactile richness, and full validation evidence.",
    "execution_context": {
      "estimated_duration_seconds": "35-60",
      "tool_calls": [
        "prompts.search (keyword ×4)",
        "conversation.remember",
        "prompts.search (hybrid, expandGraph)",
        "prompts_search_adaptive (optional)",
        "conversation.store"
      ],
      "critical_path_steps": [1, 2, 5, 6, 7]
    },
    "inputs": [
      {
        "name": "idea",
        "required": true
      },
      {
        "name": "vibe",
        "required": true
      },
      {
        "name": "sessionId",
        "required": true
      },
      {
        "name": "runId",
        "required": true
      },
      {
        "name": "projectId",
        "default": "aismr"
      }
    ],
    "steps": [
      {
        "order": 1,
        "name": "Parallel Spec Load",
        "instruction": "Fetch sacred specs simultaneously.",
        "tool": {
          "name": "prompts.search",
          "execution": {
            "parallelCalls": [
              {
                "query": "AISMR timing rule 3.0 seconds",
                "searchMode": "keyword",
                "project": "aismr",
                "useMemoryRouting": true,
                "temporalBoost": true
              },
              {
                "query": "AISMR runtime 8 seconds vertical 9:16 single shot",
                "searchMode": "keyword",
                "project": "aismr",
                "useMemoryRouting": true,
                "temporalBoost": true
              },
              {
                "query": "AISMR hand discipline max two hands",
                "searchMode": "keyword",
                "project": "aismr",
                "useMemoryRouting": true,
                "temporalBoost": true
              },
              {
                "query": "AISMR audio rule no music",
                "searchMode": "keyword",
                "project": "aismr",
                "useMemoryRouting": true,
                "temporalBoost": true
              }
            ]
          },
          "outputs": [
            "specs.timing",
            "specs.runtime",
            "specs.hands",
            "specs.audio"
          ],
          "failure_handling": "Retry each query up to two times. If any remain unresolved, HALT with `status:blocked.specLookup`."
        }
      },
      {
        "order": 2,
        "name": "Conversation Feedback Intake",
        "instruction": "Retrieve past screenplay feedback to avoid repeated issues.",
        "tool": {
          "name": "conversation.remember",
          "arguments": {
            "sessionId": "<sessionId>",
            "query": "AISMR screenplay feedback timing hand violations style notes",
            "format": "bullets",
            "limit": 10,
            "temporalBoost": true
          },
          "outputs": [
            "feedback.issues: array of {type, note}",
            "mitigationPlan: list of actions to prevent recurrence"
          ]
        }
      },
      {
        "order": 3,
        "name": "Success Pattern Mining",
        "instruction": "Study winning scripts for structure inspiration while avoiding duplication.",
        "tool": {
          "name": "prompts.search",
          "arguments": {
            "project": "aismr",
            "searchMode": "hybrid",
            "expandGraph": true,
            "maxHops": 2,
            "useMemoryRouting": true,
            "limit": 10,
            "query": "<idea keywords> AISMR screenplay"
          },
          "outputs": [
            "patternLibrary: array of {chunkId, highlight, reason}",
            "differentiationNotes: statements of how new script will diverge"
          ]
        }
      },
      {
        "order": 4,
        "name": "Adaptive Style Refinement (Optional)",
        "instruction": "Invoke when vibe or pacing guidance is unclear.",
        "tool": {
          "name": "prompts_search_adaptive",
          "arguments": {
            "project": "aismr",
            "query": "<vibe> AISMR screenplay references",
            "maxIterations": 2,
            "utilityThreshold": 0.58,
            "expandGraph": true,
            "temporalBoost": true
          },
          "outputs": [
            "adaptiveInsights: array of {iteration, utility, takeaway}"
          ],
          "exit_criteria": "Skip if archive patterns already sufficient."
        }
      },
      {
        "order": 5,
        "name": "Screenplay Drafting",
        "instruction": "Write the screenplay with explicit timestamps, sensory detail, and compliance notes.",
        "outputs": [
          "screenplayDraft: structured object with fields defined in Output Schema.",
          "complianceNotes: summary referencing specs and mitigation plan."
        ],
        "notes": [
          "Ensure whisper beat anchored exactly at 3.0s within ±0.05s tolerance.",
          "State hand positions and movements to guarantee ≤2 hands visible."
        ]
      },
      {
        "order": 6,
        "name": "Validation Pass",
        "instruction": "Confirm compliance before release.",
        "checks": [
          "Timing: whisper at 3.0s ±0.05s, total runtime 8s ±0.1s.",
          "Hand count: ≤2 and choreography prevents accidental entries.",
          "Audio: no music, only tactile foley and whisper.",
          "Motion: continuous single shot, no hidden cuts."
        ],
        "outputs": [
          "validationSummary: {timing:'pass', hands:'pass', audio:'pass', loop:'pass', notes:[]}"
        ],
        "failure_handling": "If any check fails, revise screenplay and re-run validation. On persistent failure, HALT with details."
      },
      {
        "order": 7,
        "name": "Structured Output Delivery",
        "instruction": "Return screenplay plus validation evidence and source references.",
        "outputs": [
          "screenplay: final object adhering to schema.",
          "references: array of spec chunk IDs and memory sources.",
          "validationSummary: final status."
        ]
      },
      {
        "order": 8,
        "name": "Memory Logging",
        "instruction": "Store screenplay and validation results for future retrieval.",
        "tool": {
          "name": "conversation.store",
          "arguments": {
            "sessionId": "<sessionId>",
            "role": "assistant",
            "tags": ["screenplay", "aismr", "completed"],
            "content": "Screenplay for <idea>",
            "summary": {
              "idea": "<idea>",
              "runtime": 8,
              "whisperAt": 3.0,
              "hands": "<=2",
              "validation": "pass",
              "runId": "<runId>"
            }
          }
        }
      }
    ],
    "validation_checklist": [
      "Four spec searches executed and recorded.",
      "Conversation feedback consulted and addressed.",
      "Screenplay includes explicit timestamps, environment, materials, audio, loop mechanic.",
      "Validation summary present with pass/fail for each spec.",
      "References include spec chunk IDs or memory IDs for traceability."
    ]
  },
  "output_schema": {
    "type": "object",
    "required": [
      "title",
      "logline",
      "timestamps",
      "camera",
      "materials",
      "audio",
      "handDiscipline",
      "loopMechanic",
      "validationSummary"
    ],
    "properties": {
      "title": {
        "type": "string"
      },
      "logline": {
        "type": "string"
      },
      "timestamps": {
        "type": "array",
        "items": {
          "type": "object",
          "required": ["time", "action", "sensoryDetail"],
          "properties": {
            "time": {
              "type": "string",
              "pattern": "^\\d+\\.\\d+s$"
            },
            "action": {
              "type": "string"
            },
            "sensoryDetail": {
              "type": "string"
            }
          }
        }
      },
      "camera": {
        "type": "string"
      },
      "materials": {
        "type": "string"
      },
      "audio": {
        "type": "string",
        "description": "Detail tactile foley, whisper integration, and confirmation of no music."
      },
      "handDiscipline": {
        "type": "string",
        "description": "Explicit hand choreography ensuring ≤2 hands."
      },
      "loopMechanic": {
        "type": "string"
      },
      "validationSummary": {
        "type": "object",
        "required": ["timing", "hands", "audio", "loop", "notes"],
        "properties": {
          "timing": {
            "type": "string"
          },
          "hands": {
            "type": "string"
          },
          "audio": {
            "type": "string"
          },
          "loop": {
            "type": "string"
          },
          "notes": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    }
  }
}
